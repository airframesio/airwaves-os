  {
    "id": "acarsdec",
    "name": "acarsdec",
    "description": "Multi-channel ACARS decoder. Receives VHF ACARS messages on frequencies around 130-136 MHz and outputs decoded text for feeding to ACARS Hub or aggregators.",
    "version": "latest",
    "category": "decoder",
    "image": "ghcr.io/sdr-enthusiasts/docker-acarsdec:latest",
    "icon": null,
    "ports": [],
    "requires_sdr": true,
    "sdr_types": [
      "rtl_sdr",
      "airspy"
    ],
    "env": {
      "SOAPYSDR": "driver=rtlsdr",
      "FREQUENCIES": "130.025;130.450;131.125;131.550",
      "FEED_ID": "",
      "TZ": "UTC"
    },
    "config_fields": [
      {
        "key": "SOAPYSDR",
        "label": "SDR device",
        "help": "Select which connected SDR acarsdec should use.",
        "kind": "sdr",
        "default": "driver=rtlsdr",
        "required": true
      },
      {
        "key": "FREQUENCIES",
        "label": "Frequencies (MHz)",
        "help": "Semicolon-separated VHF ACARS frequencies, e.g. 130.025;130.450;131.125;131.550",
        "kind": "text",
        "default": "130.025;130.450;131.125;131.550",
        "required": true
      },
      {
        "key": "FEED_ID",
        "label": "Feed ID",
        "help": "Optional station/feed identifier sent with messages.",
        "kind": "text",
        "default": "",
        "required": false
      },
      {
        "key": "GAIN",
        "label": "Gain (dB)",
        "help": "Receiver gain. Leave default for automatic.",
        "kind": "text",
        "default": "auto",
        "required": false
      },
      {
        "key": "TZ",
        "label": "Timezone",
        "kind": "text",
        "default": "UTC",
        "required": false
      }
    ]
  },
