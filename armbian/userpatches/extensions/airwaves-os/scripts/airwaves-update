#!/usr/bin/env bash
#
# Airwaves OS host-side updater.
#
# Runs as root on the HOST (via airwaves-update.service), triggered by the
# manager which writes a job spec to /etc/airwaves/update/request.json. Because
# this runs outside the container stack, it can safely recreate the manager and
# gateway containers. Progress is written to /etc/airwaves/update/status.json,
# which the manager serves back to the control app (it survives the manager
# being recreated mid-update).
#
# Honors AIRWAVES_UPDATE_DRYRUN=1 to log actions without mutating anything.

set -uo pipefail

AIRWAVES_DIR="/etc/airwaves"
COMPOSE="${AIRWAVES_DIR}/docker-compose.yml"
CATALOG="${AIRWAVES_DIR}/catalog.json"
VERSIONS="${AIRWAVES_DIR}/.versions.json"
CONFIG="${AIRWAVES_DIR}/config.json"
UPDATE_DIR="${AIRWAVES_DIR}/update"
REQUEST="${UPDATE_DIR}/request.json"
STATUS="${UPDATE_DIR}/status.json"
BACKUP_DIR="${UPDATE_DIR}/backup"
BACKUPS_DIR="${UPDATE_DIR}/backups"
LOGFILE="/var/log/airwaves-update.log"
HEALTH_TIMEOUT="${AIRWAVES_HEALTH_TIMEOUT:-120}"
IMAGE_PULL_TIMEOUT="${AIRWAVES_IMAGE_PULL_TIMEOUT:-1500}"
STATUS_LOG_LINES="${AIRWAVES_STATUS_LOG_LINES:-200}"
DRYRUN="${AIRWAVES_UPDATE_DRYRUN:-0}"

mkdir -p "${UPDATE_DIR}" "${BACKUP_DIR}" "${BACKUPS_DIR}"
: > "${UPDATE_DIR}/.log.tmp" 2>/dev/null || true
LOG_TMP="${UPDATE_DIR}/.log.tmp"

STATE="running"
PHASE="starting"
PERCENT=0
REBOOT_REQUIRED="false"
ERROR=""
STARTED_AT="$(date -u +%Y-%m-%dT%H:%M:%SZ)"

# ---- helpers ---------------------------------------------------------------

log() {
    local line
    line="[$(date -u +%H:%M:%S)] $*"
    echo "${line}" | tee -a "${LOGFILE}" >&2
    echo "${line}" >> "${LOG_TMP}"
}

write_status() {
    local finished="${1:-}"
    local finished_field="null"
    if [ -n "${finished}" ]; then
        finished_field="\"${finished}\""
    fi
    local err_field="null"
    if [ -n "${ERROR}" ]; then
        err_field="$(jq -Rn --arg e "${ERROR}" '$e')"
    fi
    jq -Rn \
        --arg state "${STATE}" \
        --arg phase "${PHASE}" \
        --argjson percent "${PERCENT}" \
        --argjson reboot "${REBOOT_REQUIRED}" \
        --arg started "${STARTED_AT}" \
        --slurpfile loglines <(tail -n "${STATUS_LOG_LINES}" "${LOG_TMP}" 2>/dev/null | jq -R .) \
        "{
            state: \$state,
            phase: \$phase,
            percent: \$percent,
            reboot_required: \$reboot,
            error: ${err_field},
            started_at: \$started,
            finished_at: ${finished_field},
            log: \$loglines
        }" > "${STATUS}.tmp" 2>/dev/null && mv "${STATUS}.tmp" "${STATUS}"
}

phase() {
    PHASE="$1"
    PERCENT="${2:-$PERCENT}"
    log "==> ${PHASE}"
    write_status
}

fail() {
    STATE="failed"
    ERROR="$1"
    log "ERROR: ${ERROR}"
    write_status "$(date -u +%Y-%m-%dT%H:%M:%SZ)"
}

run() {
    if [ "${DRYRUN}" = "1" ]; then
        log "[dry-run] $*"
        return 0
    fi
    log "\$ $*"
    "$@" >>"${LOGFILE}" 2>&1
}

run_with_heartbeat() {
    # run_with_heartbeat <timeout_seconds> <command> [args...]
    #
    # Long-running commands such as `docker compose pull` can sit on network or
    # layer-unpack work without returning. Keep status.json fresh while they run,
    # stream command output into the UI log, and fail cleanly before systemd kills
    # the oneshot service with no final status.
    local timeout_seconds="$1"
    shift
    if [ "${DRYRUN}" = "1" ]; then
        log "[dry-run] $*"
        return 0
    fi

    log "\$ $*"
    "$@" > >(tee -a "${LOGFILE}" >> "${LOG_TMP}") 2>&1 &
    local pid=$!
    local started now rc=0
    started="$(date +%s)"

    while kill -0 "${pid}" 2>/dev/null; do
        sleep 5
        now="$(date +%s)"
        if [ "${timeout_seconds:-0}" -gt 0 ] && [ $((now - started)) -ge "${timeout_seconds}" ]; then
            log "Command timed out after ${timeout_seconds}s: $*"
            kill "${pid}" 2>/dev/null || true
            sleep 2
            kill -9 "${pid}" 2>/dev/null || true
            wait "${pid}" 2>/dev/null || true
            write_status
            return 124
        fi
        write_status
    done

    wait "${pid}" || rc=$?
    write_status
    return "${rc}"
}

want() {
    # True if component "$1" (or "all") is in the request component list.
    echo "${COMPONENTS}" | jq -e --arg c "$1" 'index($c) != null or index("all") != null' >/dev/null 2>&1
}

# Last lines of the log, flattened — used to surface the real cause of a failure.
log_tail() {
    tail -n 15 "${LOGFILE}" 2>/dev/null | tr '\n' ' ' | sed 's/  */ /g'
}

# Free space on the root filesystem, in MB.
free_mb() {
    df -Pk / | awk 'NR==2 {print int($4 / 1024)}'
}

verify_sha256() {
    local file="$1" expected="$2"
    [ -z "${expected}" ] && return 0
    local actual
    actual="$(sha256sum "${file}" | awk '{print $1}')"
    [ "${actual}" = "${expected}" ]
}

container_healthy() {
    # Returns 0 if the container reports healthy (or running with no healthcheck).
    local name="$1" health status
    health="$(docker inspect -f '{{if .State.Health}}{{.State.Health.Status}}{{else}}none{{end}}' "${name}" 2>/dev/null)" || return 1
    status="$(docker inspect -f '{{.State.Status}}' "${name}" 2>/dev/null)" || return 1
    case "${health}" in
        healthy) return 0 ;;
        none) [ "${status}" = "running" ] && return 0 || return 1 ;;
        *) return 1 ;;
    esac
}

wait_healthy() {
    local deadline=$(( $(date +%s) + HEALTH_TIMEOUT ))
    log "Waiting up to ${HEALTH_TIMEOUT}s for containers to become healthy..."
    while [ "$(date +%s)" -lt "${deadline}" ]; do
        if container_healthy airwaves-manager && container_healthy airwaves-gateway; then
            log "Containers healthy."
            return 0
        fi
        sleep 3
    done
    # Timed out — log each container's actual state + health so the rollback
    # reason is obvious in the update log (e.g. an image whose healthcheck binary
    # is missing shows "unhealthy" forever).
    local c st he
    for c in airwaves-manager airwaves-gateway; do
        st="$(docker inspect -f '{{.State.Status}}' "${c}" 2>/dev/null || echo missing)"
        he="$(docker inspect -f '{{if .State.Health}}{{.State.Health.Status}}{{else}}none{{end}}' "${c}" 2>/dev/null || echo n/a)"
        log "Health timeout: ${c} status=${st} health=${he}"
    done
    return 1
}

compose() {
    docker compose -f "${COMPOSE}" "$@"
}

# Rewrite the tag of a specific image in docker-compose.yml so the next pull
# fetches an immutable version tag instead of :latest. Idempotent.
pin_image_tag() {
    local image="$1" tag="$2"
    [ -f "${COMPOSE}" ] || return 0
    # Escape regex metacharacters in the image path (dots, slashes).
    local esc
    esc="$(printf '%s' "${image}" | sed -e 's/[.[\*^$()+?{|]/\\&/g' -e 's#/#\\/#g')"
    if [ "${DRYRUN}" = "1" ]; then
        log "[dry-run] pin ${image} -> :${tag}"
        return 0
    fi
    sed -i -E "s#(${esc}):[^\"'[:space:]]+#\\1:${tag}#g" "${COMPOSE}"
    log "Pinned ${image} -> :${tag}"
}

download() {
    # download <url> <dest> <sha256>
    local url="$1" dest="$2" sha="$3"
    log "Downloading ${url}"
    if [ "${DRYRUN}" = "1" ]; then
        log "[dry-run] skip download"
        return 0
    fi
    if ! curl -fsSL "${url}" -o "${dest}.new"; then
        return 1
    fi
    if ! verify_sha256 "${dest}.new" "${sha}"; then
        log "Checksum mismatch for ${dest}"
        rm -f "${dest}.new"
        return 1
    fi
    mv "${dest}.new" "${dest}"
    return 0
}

# ---- main ------------------------------------------------------------------

main() {
    write_status

    if [ ! -f "${REQUEST}" ]; then
        fail "No update request found at ${REQUEST}"
        return 1
    fi

    COMPONENTS="$(jq -c '.components // []' "${REQUEST}")"
    log "Requested components: ${COMPONENTS}"

    phase "backing-up" 5
    log "Backing up current configuration before updating (so changes can be rolled back)..."

    # Snapshot config + current image digests for rollback. BACKUP_DIR is the
    # working copy used for automatic rollback within this run.
    [ -f "${COMPOSE}" ] && cp -f "${COMPOSE}" "${BACKUP_DIR}/docker-compose.yml"
    [ -f "${CATALOG}" ] && cp -f "${CATALOG}" "${BACKUP_DIR}/catalog.json"
    [ -f "${VERSIONS}" ] && cp -f "${VERSIONS}" "${BACKUP_DIR}/.versions.json"
    [ -f "${CONFIG}" ] && cp -f "${CONFIG}" "${BACKUP_DIR}/config.json"
    : > "${BACKUP_DIR}/digests.txt"
    for cname in airwaves-manager airwaves-gateway; do
        local pre_id
        pre_id="$(docker inspect -f '{{.Image}}' "${cname}" 2>/dev/null || true)"
        [ -n "${pre_id}" ] && echo "${cname} ${pre_id}" >> "${BACKUP_DIR}/digests.txt"
    done

    # Also keep a timestamped, retained snapshot the user can restore from later,
    # independent of the next update's rollback working copy.
    if [ "${DRYRUN}" != "1" ]; then
        local snap_ts snap_dir
        snap_ts="$(date -u +%Y%m%dT%H%M%SZ)"
        snap_dir="${BACKUPS_DIR}/${snap_ts}"
        mkdir -p "${snap_dir}"
        for f in "${COMPOSE}" "${CATALOG}" "${VERSIONS}" "${CONFIG}"; do
            [ -f "${f}" ] && cp -f "${f}" "${snap_dir}/" 2>/dev/null || true
        done
        cp -f "${BACKUP_DIR}/digests.txt" "${snap_dir}/digests.txt" 2>/dev/null || true
        log "Configuration backed up to ${snap_dir}"
        # Retain only the most recent 10 snapshots.
        ls -1dt "${BACKUPS_DIR}"/*/ 2>/dev/null | tail -n +11 | xargs -r rm -rf
    fi

    # ---- host files (userpatches: scripts, systemd units, config) ----------
    # Sync any manifest-declared host files so userpatch changes reach the
    # device without a reflash. Atomic per-file; daemon-reload if a unit changed.
    local hf_count
    hf_count="$(jq -r '.host_files | length' "${REQUEST}" 2>/dev/null || echo 0)"
    if [ "${hf_count}" -gt 0 ] 2>/dev/null; then
        phase "syncing-host-files" 30
        local need_daemon_reload="false" i
        for i in $(seq 0 $((hf_count - 1))); do
            local hf_url hf_dest hf_mode hf_sha
            hf_url="$(jq -r ".host_files[$i].url // empty" "${REQUEST}")"
            hf_dest="$(jq -r ".host_files[$i].dest // empty" "${REQUEST}")"
            hf_mode="$(jq -r ".host_files[$i].mode // empty" "${REQUEST}")"
            hf_sha="$(jq -r ".host_files[$i].sha256 // empty" "${REQUEST}")"
            if [ -z "${hf_url}" ] || [ -z "${hf_dest}" ]; then continue; fi
            # These files are written as host root, so the destination must be
            # locked down. Reject relative paths and any traversal/double-slash
            # BEFORE canonicalizing, then verify the canonical path still falls
            # inside an allow-listed root (defends against e.g.
            # /opt/airwaves/../../etc/sudoers slipping past a prefix match).
            case "${hf_dest}" in
                *..*|*//*) log "Refusing host file with unsafe dest: ${hf_dest}"; continue ;;
            esac
            if [ "${hf_dest#/}" = "${hf_dest}" ]; then
                log "Refusing relative host-file dest: ${hf_dest}"; continue
            fi
            local hf_dest_canon
            hf_dest_canon="$(realpath -m "${hf_dest}")"
            case "${hf_dest_canon}" in
                /opt/airwaves/*|/etc/airwaves/*|/etc/systemd/system/*|/etc/update-motd.d/*|/etc/udev/rules.d/*) ;;
                *) log "Refusing host file with disallowed dest: ${hf_dest}"; continue ;;
            esac
            hf_dest="${hf_dest_canon}"
            # Integrity is mandatory: a host file with no sha256 could let a
            # tampered/served-wrong file land as root. Skip (don't fail the
            # whole update) and log loudly.
            if [ -z "${hf_sha}" ]; then
                log "Refusing host file without sha256: ${hf_dest}"; continue
            fi
            if [ "${DRYRUN}" = "1" ]; then
                log "[dry-run] would sync ${hf_url} -> ${hf_dest}"
                continue
            fi
            mkdir -p "$(dirname "${hf_dest}")"
            if ! download "${hf_url}" "${hf_dest}" "${hf_sha}"; then
                log "WARNING: failed to sync ${hf_dest}; skipping"
                continue
            fi
            [ -n "${hf_mode}" ] && chmod "${hf_mode}" "${hf_dest}"
            case "${hf_dest}" in
                /etc/systemd/system/*) need_daemon_reload="true" ;;
            esac
            log "Synced host file -> ${hf_dest}"
        done
        if [ "${need_daemon_reload}" = "true" ] && [ "${DRYRUN}" != "1" ]; then
            systemctl daemon-reload || true
        fi
    fi

    # ---- compose + catalog config -----------------------------------------
    if want compose; then
        local url sha ver
        url="$(jq -r '.compose_url // empty' "${REQUEST}")"
        sha="$(jq -r '.compose_sha256 // empty' "${REQUEST}")"
        ver="$(jq -r '.compose_version // empty' "${REQUEST}")"
        if [ -n "${url}" ]; then
            phase "downloading-compose" 15
            if ! download "${url}" "${COMPOSE}" "${sha}"; then
                fail "Failed to download/verify docker-compose.yml"
                rollback_config
                return 1
            fi
            [ -n "${ver}" ] && update_version_marker compose "${ver}"
        fi
    fi

    if want catalog; then
        local url sha ver
        url="$(jq -r '.catalog_url // empty' "${REQUEST}")"
        sha="$(jq -r '.catalog_sha256 // empty' "${REQUEST}")"
        ver="$(jq -r '.catalog_version // empty' "${REQUEST}")"
        if [ -n "${url}" ]; then
            phase "downloading-catalog" 25
            if ! download "${url}" "${CATALOG}" "${sha}"; then
                fail "Failed to download/verify catalog.json"
                rollback_config
                return 1
            fi
            [ -n "${ver}" ] && update_version_marker catalog "${ver}"
        fi
    fi

    # ---- container images --------------------------------------------------
    if want manager || want gateway || want compose || [ "${RECREATE}" = "true" ]; then
        phase "pulling-images" 40
        # Image pulls download + unpack layers; ensure there's headroom first.
        local avail_img
        avail_img="$(free_mb)"
        if [ "${avail_img:-0}" -lt 1500 ]; then
            log "Low disk (${avail_img} MB); reclaiming space before pull"
            run docker image prune -f
            run apt-get clean
            avail_img="$(free_mb)"
        fi
        if [ "${avail_img:-0}" -lt 1000 ]; then
            fail "Not enough free disk space to pull images (${avail_img} MB free; need ~1000 MB). Expand the disk, then try again."
            rollback_config
            return 1
        fi

        # Pin BOTH compose image tags to the manifest's channel tags whenever the
        # stack is pulled, so the pull fetches specific versions (not :latest) and
        # both images stay aligned with the selected channel — even if only one
        # component triggered this update. The manager always writes both pins.
        # In repair mode we deliberately do NOT touch image tags — we re-pull
        # whatever is currently pinned in the compose file. Otherwise pin both
        # images to the manifest's channel tags (manager always writes both).
        if [ "${RECREATE}" = "true" ]; then
            log "Repair mode: re-pulling currently pinned images (no tag changes)"
        else
            local mgr_img mgr_tag gw_img gw_tag
            mgr_img="$(jq -r '.manager_image // empty' "${REQUEST}")"
            mgr_tag="$(jq -r '.manager_tag // empty' "${REQUEST}")"
            gw_img="$(jq -r '.gateway_image // empty' "${REQUEST}")"
            gw_tag="$(jq -r '.gateway_tag // empty' "${REQUEST}")"
            [ -n "${mgr_img}" ] && [ -n "${mgr_tag}" ] && pin_image_tag "${mgr_img}" "${mgr_tag}"
            [ -n "${gw_img}" ] && [ -n "${gw_tag}" ] && pin_image_tag "${gw_img}" "${gw_tag}"
        fi

        if ! run_with_heartbeat "${IMAGE_PULL_TIMEOUT}" compose pull; then
            # Keep the error concise — the full log is already captured in the
            # status log array; embedding the tail here duplicated it in the UI.
            fail "docker compose pull failed or timed out (see log below)"
            rollback_config
            return 1
        fi

        phase "recreating-containers" 60
        # This may recreate the manager (this script keeps running on the host).
        # Repair mode forces recreation even when the image digest is unchanged.
        local up_args="-d --remove-orphans"
        [ "${RECREATE}" = "true" ] && up_args="-d --remove-orphans --force-recreate"
        # shellcheck disable=SC2086
        if ! run compose up ${up_args}; then
            fail "docker compose up failed"
            rollback_full
            return 1
        fi

        phase "health-check" 75
        if [ "${DRYRUN}" != "1" ] && ! wait_healthy; then
            fail "Containers did not become healthy; rolling back"
            rollback_full
            return 1
        fi

        # Digest gate: warn if a requested container's image didn't actually
        # change (e.g. :latest pointed at the same image we already had).
        if [ "${DRYRUN}" != "1" ] && [ -f "${BACKUP_DIR}/digests.txt" ]; then
            for cname in airwaves-manager airwaves-gateway; do
                case "${cname}" in
                    airwaves-manager) want manager || continue ;;
                    airwaves-gateway) want gateway || continue ;;
                esac
                local before after
                before="$(awk -v n="${cname}" '$1==n{print $2}' "${BACKUP_DIR}/digests.txt" 2>/dev/null)"
                after="$(docker inspect -f '{{.Image}}' "${cname}" 2>/dev/null)"
                if [ -n "${before}" ] && [ "${before}" = "${after}" ]; then
                    log "WARNING: ${cname} image did not change (${after}); the pulled tag may already be current."
                fi
            done
        fi
    fi

    # ---- base OS packages --------------------------------------------------
    if want os_packages; then
        phase "updating-os-packages" 85
        # Reclaim cache space and recover any interrupted dpkg state first.
        run apt-get clean
        run dpkg --configure -a
        run apt-get -y -f install

        local avail
        avail="$(free_mb)"
        if [ "${avail:-0}" -lt 800 ]; then
            fail "Not enough free disk space for OS updates (${avail} MB free; need ~800 MB). Free up space or expand the disk, then try again."
            return 1
        fi

        if ! run apt-get update; then
            fail "apt-get update failed: $(log_tail)"
            return 1
        fi
        local kernel_before kernel_after
        kernel_before="$(dpkg -l 'linux-image*' 2>/dev/null | grep -c '^ii' || true)"
        if ! run env DEBIAN_FRONTEND=noninteractive apt-get -y -o Dpkg::Options::=--force-confold upgrade; then
            fail "apt-get upgrade failed: $(log_tail)"
            return 1
        fi
        kernel_after="$(dpkg -l 'linux-image*' 2>/dev/null | grep -c '^ii' || true)"
        if [ "${kernel_before}" != "${kernel_after}" ]; then
            REBOOT_REQUIRED="true"
        fi
    fi

    # ---- major OS upgrade (in-place) ---------------------------------------
    if want os_major; then
        local target
        target="$(jq -r '.os_major_to // empty' "${REQUEST}")"
        if [ -n "${target}" ]; then
            phase "os-major-upgrade" 90
            log "In-place major upgrade to ${target} (this can take a while)"
            run apt-get clean
            run dpkg --configure -a

            # Major upgrades need substantial headroom (downloads + unpack).
            local avail
            avail="$(free_mb)"
            if [ "${avail:-0}" -lt 3000 ]; then
                fail "Not enough free disk space for a major OS upgrade (${avail} MB free; need ~3000 MB). Expand the disk, then try again."
                return 1
            fi

            # Repoint apt sources at the new release codename, then full-upgrade.
            run sed -i.airwaves-bak -E "s/(bookworm|trixie|bullseye)/${target}/g" /etc/apt/sources.list
            if [ -d /etc/apt/sources.list.d ]; then
                for f in /etc/apt/sources.list.d/*.list; do
                    [ -e "${f}" ] || continue
                    case "${f}" in
                        *docker*) continue ;;  # docker repo handled separately
                    esac
                    run sed -i.airwaves-bak -E "s/(bookworm|trixie|bullseye)/${target}/g" "${f}"
                done
            fi
            if ! run apt-get update; then
                fail "apt-get update failed after repointing sources: $(log_tail)"
                return 1
            fi
            if ! run env DEBIAN_FRONTEND=noninteractive apt-get -y -o Dpkg::Options::=--force-confold full-upgrade; then
                fail "Major upgrade failed: $(log_tail)"
                return 1
            fi
            REBOOT_REQUIRED="true"
        fi
    fi

    STATE="success"
    phase "done" 100
    write_status "$(date -u +%Y-%m-%dT%H:%M:%SZ)"
    log "Update completed successfully (reboot_required=${REBOOT_REQUIRED})"
    return 0
}

rollback_config() {
    log "Rolling back config files from backup"
    [ -f "${BACKUP_DIR}/docker-compose.yml" ] && cp -f "${BACKUP_DIR}/docker-compose.yml" "${COMPOSE}"
    [ -f "${BACKUP_DIR}/catalog.json" ] && cp -f "${BACKUP_DIR}/catalog.json" "${CATALOG}"
    [ -f "${BACKUP_DIR}/.versions.json" ] && cp -f "${BACKUP_DIR}/.versions.json" "${VERSIONS}"
    STATE="rolled_back"
    write_status "$(date -u +%Y-%m-%dT%H:%M:%SZ)"
}

rollback_full() {
    rollback_config
    log "Re-applying previous stack"
    run compose up -d --remove-orphans || true
}

update_version_marker() {
    # update_version_marker <key> <value>
    local key="$1" val="$2"
    [ -f "${VERSIONS}" ] || echo '{}' > "${VERSIONS}"
    jq --arg k "${key}" --argjson v "${val}" '.[$k] = $v' "${VERSIONS}" > "${VERSIONS}.tmp" \
        && mv "${VERSIONS}.tmp" "${VERSIONS}"
}

main "$@"
exit $?
