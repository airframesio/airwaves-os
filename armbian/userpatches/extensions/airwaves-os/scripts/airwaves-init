#!/usr/bin/env bash
set -euo pipefail

# Airwaves OS Initialization Script
# Runs on first boot to configure the system and load pre-baked containers.
# Subsequent boots are handled by airwaves-containers.service directly.

AIRWAVES_CONFIG="/etc/airwaves/config.json"
AIRWAVES_IMAGES_DIR="/opt/airwaves/images"
AIRWAVES_MARKER="/opt/airwaves/.needs-first-run"
AIRWAVES_INITIALIZED="/opt/airwaves/.initialized"
AIRWAVES_VERSIONS="/etc/airwaves/.versions.json"
AIRWAVES_COMPOSE="/etc/airwaves/docker-compose.yml"

log() {
    echo "[airwaves-init] $*"
    logger -t airwaves-init "$*"
}

channel_alias() {
    # Map the device's release channel to the moving image tag CI publishes:
    # dev->:dev, beta->:beta, stable->:stable. Each channel has its own moving
    # tag (the stable build also pushes :latest, but :stable is the canonical
    # per-channel pointer and is what we rely on). Honoring the channel here
    # means a dev-channel image boots dev images on first boot, not stable.
    local ch="stable"
    [ -f "$AIRWAVES_VERSIONS" ] && ch="$(jq -r '.channel // "stable"' "$AIRWAVES_VERSIONS" 2>/dev/null || echo stable)"
    case "$ch" in
        dev)    echo "dev" ;;
        beta)   echo "beta" ;;
        stable) echo "stable" ;;
        *)      echo "stable" ;;   # unknown channels fall back to stable
    esac
}

pin_compose_to_alias() {
    # The compose template ships :latest; rewrite the airwaves image tags to the
    # channel alias so `docker compose up` runs the same images we just pulled.
    # For a stable device (alias=latest) this is a no-op.
    local alias="$1"
    [ -f "$AIRWAVES_COMPOSE" ] || return 0
    sed -i -E "s#(ghcr\.io/airframesio/airwaves-(gateway|manager)):[^\"'[:space:]]+#\\1:${alias}#g" "$AIRWAVES_COMPOSE"
    log "Pinned compose airwaves images -> :${alias}"
}

ensure_user_home() {
    # Self-heal the airwaves home dir if a build/copy ever left it missing (SSH
    # login fails with "Could not chdir to home directory" otherwise).
    if id airwaves >/dev/null 2>&1 && [ ! -d /home/airwaves ]; then
        log "Creating missing /home/airwaves"
        mkdir -p /home/airwaves
        cp -rTn /etc/skel /home/airwaves 2>/dev/null || true
        chown -R airwaves:airwaves /home/airwaves
        chmod 755 /home/airwaves
    fi
}

generate_device_id() {
    log "Generating device ID..."
    local uuid
    uuid=$(cat /proc/sys/kernel/random/uuid)
    jq --arg id "$uuid" '.device.id = $id' "$AIRWAVES_CONFIG" > /tmp/config.json.tmp
    mv /tmp/config.json.tmp "$AIRWAVES_CONFIG"
    log "Device ID: $uuid"
}

set_hostname() {
    # Respect a hostname already chosen by airwaves-preconfig (AWCFG config
    # partition), which runs before us. If config.device.hostname is set, use it
    # instead of deriving one from the MAC.
    local preset=""
    [ -f "$AIRWAVES_CONFIG" ] && preset="$(jq -r '.device.hostname // empty' "$AIRWAVES_CONFIG" 2>/dev/null)"
    if [ -n "$preset" ]; then
        log "Using preconfigured hostname: ${preset}"
        hostnamectl set-hostname "${preset}" 2>/dev/null || true
        echo "${preset}" > /etc/hostname
        systemctl restart avahi-daemon 2>/dev/null || true
        return 0
    fi

    log "Setting hostname from MAC address..."

    # Find the primary network interface MAC
    local mac_suffix=""
    for iface in eth0 end0 enp0s3 ens3; do
        if [ -f "/sys/class/net/${iface}/address" ]; then
            mac_suffix=$(cat "/sys/class/net/${iface}/address" | awk -F: '{print $4$5$6}')
            break
        fi
    done

    # Fallback: use first non-loopback interface
    if [ -z "$mac_suffix" ]; then
        local first_iface
        first_iface=$(ip -o link show | awk -F': ' '{print $2}' | grep -v lo | head -1)
        if [ -n "$first_iface" ] && [ -f "/sys/class/net/${first_iface}/address" ]; then
            mac_suffix=$(cat "/sys/class/net/${first_iface}/address" | awk -F: '{print $4$5$6}')
        fi
    fi

    # Final fallback: random suffix
    if [ -z "$mac_suffix" ]; then
        mac_suffix=$(head -c 3 /dev/urandom | xxd -p)
    fi

    local new_hostname="airwaves-${mac_suffix}"
    log "Setting hostname: ${new_hostname}"

    hostnamectl set-hostname "${new_hostname}"
    echo "${new_hostname}" > /etc/hostname

    # Update config
    jq --arg hostname "$new_hostname" '.device.hostname = $hostname' "$AIRWAVES_CONFIG" > /tmp/config.json.tmp
    mv /tmp/config.json.tmp "$AIRWAVES_CONFIG"

    # Restart avahi to pick up new hostname
    systemctl restart avahi-daemon 2>/dev/null || true
}

images_present() {
    # True only if BOTH airwaves images are already in the local docker store
    # for the given tag (e.g. pre-extracted into /var/lib/docker at image build).
    local alias="$1" img
    for img in airwaves-gateway airwaves-manager; do
        docker image inspect "ghcr.io/airframesio/${img}:${alias}" >/dev/null 2>&1 || return 1
    done
    return 0
}

load_prebaked_containers() {
    log "Loading container images..."

    local alias
    alias="$(channel_alias)"

    # Fast path: the images were pre-extracted into the docker store at build time
    # (lean live-USB image). Nothing to load — just align the compose tags and go.
    if images_present "$alias"; then
        log "Container images already present (pre-extracted at build); skipping load"
        pin_compose_to_alias "$alias"
        # Drop any leftover tarballs (none expected in the lean image) to reclaim space.
        rm -f "$AIRWAVES_IMAGES_DIR"/*.tar 2>/dev/null || true
        return 0
    fi

    # Try loading from pre-baked tarballs first. These are docker-save'd at image
    # BUILD time (see build-image-simple.yml) from the manager+gateway images of
    # the release pinned in releases/<channel>.json, so first boot needs NO
    # network: the system can come up (and serve the manager/web UI for Wi-Fi
    # setup) even with no connectivity. Each tarball carries the version tag, the
    # channel alias (e.g. :stable), and :latest, so whatever the compose file
    # references resolves locally.
    if [ -d "$AIRWAVES_IMAGES_DIR" ] && [ -n "$(ls -A "$AIRWAVES_IMAGES_DIR"/*.tar 2>/dev/null)" ]; then
        for image_tar in "$AIRWAVES_IMAGES_DIR"/*.tar; do
            local image_name
            image_name=$(basename "$image_tar" .tar)
            log "Loading image from tarball: ${image_name}..."
            if docker load < "$image_tar"; then
                log "Loaded: ${image_name}"
                rm -f "$image_tar"
            else
                log "WARNING: Failed to load ${image_name}"
            fi
        done
        # Point compose at the channel alias the tarballs carry so `docker compose
        # up` uses the loaded images instead of trying to pull :latest online.
        pin_compose_to_alias "${alias}"
        log "Pre-baked container loading complete (offline)"
        return 0
    fi

    # No tarballs - pull from GHCR registry for this device's release channel.
    log "No pre-baked images found, pulling from registry..."
    local registry="ghcr.io/airframesio"
    log "Release channel image tag: :${alias}"

    for image in airwaves-gateway airwaves-manager; do
        log "Pulling ${registry}/${image}:${alias}..."
        if docker pull "${registry}/${image}:${alias}"; then
            log "Pulled: ${image}"
        else
            log "WARNING: Failed to pull ${image} - will retry on next boot"
        fi
    done

    # Keep the compose file's image tags aligned with what we just pulled.
    pin_compose_to_alias "${alias}"

    log "Container pull complete"
}

start_containers() {
    log "Starting Airwaves OS containers..."

    if [ -f /etc/airwaves/docker-compose.yml ]; then
        cd /etc/airwaves
        docker compose up -d --remove-orphans 2>&1 | while read -r line; do log "  $line"; done
        log "Containers started"
    else
        log "WARNING: No docker-compose.yml found at /etc/airwaves/"
    fi
}

setup_docker_networks() {
    log "Ensuring Docker networks exist..."

    docker network inspect airwaves-core >/dev/null 2>&1 || \
        docker network create airwaves-core
    docker network inspect airwaves-apps >/dev/null 2>&1 || \
        docker network create airwaves-apps

    log "Docker networks ready"
}

finalize() {
    log "Marking initialization as complete"
    rm -f "$AIRWAVES_MARKER"
    touch "$AIRWAVES_INITIALIZED"
    date -u +"%Y-%m-%dT%H:%M:%SZ" > "$AIRWAVES_INITIALIZED"
    log "Airwaves OS initialization complete"
}

# Main
log "Starting Airwaves OS first-boot initialization..."

ensure_user_home
generate_device_id
set_hostname
setup_docker_networks
load_prebaked_containers
start_containers
finalize

log "First-boot initialization finished successfully"
