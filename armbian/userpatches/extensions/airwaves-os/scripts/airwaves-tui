#!/bin/bash
#
# airwaves-tui — the persistent Airwaves OS console menu shown on the main VT
# (tty1). Renders a colorful banner box + live status and offers actions
# appropriate to the system: a LIVE USB emphasises Install; an INSTALLED system
# offers Configuration, Upgrade, Repair, etc.
#
# Configuration is driven through the manager API (like the web UI) whenever the
# manager is reachable. If the manager is NOT responding, Config offers a local
# RESCUE fallback for Wi-Fi (and a couple of other basics) using host tools
# (nmcli/hostnamectl), after warning the operator that direct changes bypass the
# manager and may need reconciliation once it is back up.
#
# Launched from the tty1 autologin session (see /etc/profile.d/zz-airwaves-tui.sh
# + the getty@tty1 autologin drop-in). It LOOPS FOREVER — every action returns to
# the menu, and it never exits on its own; if it dies, getty respawns it, so tty1
# can never dead-end. Serial console and SSH get a normal shell, not this menu.
#
set -uo pipefail

FIRSTRUN="/opt/airwaves/scripts/airwaves-firstrun"   # the install sub-flow (--install)
API="http://localhost/api/v1"                         # manager API via the gateway
VERSIONS="/etc/airwaves/.versions.json"
RELEASE="/etc/airwaves-release"
FIRSTRUN_MARKER="/opt/airwaves/.needs-first-run"
TRIGGER="/run/airwaves/auto-install.json"     # armed by airwaves-preconfig (AWCFG)
INSTALL="/opt/airwaves/scripts/airwaves-install"
ISTATUS="/etc/airwaves/install/status.json"
BT="Airwaves OS"
export TERM="${TERM:-linux}"

# Shared branded look: night-watch palette remap, the flat amber dialog theme,
# the wordmark banner, and \Z/UTF-8-aware centering. Lives next to this script
# (ships in /opt/airwaves/scripts). Source it; degrade gracefully (still a working
# menu, just unbranded) if it is ever missing — tty1 must never dead-end.
LIB="$(dirname "$0")/airwaves-tui-lib.sh"
[ -r "$LIB" ] || LIB="/opt/airwaves/scripts/airwaves-tui-lib.sh"
# shellcheck source=/dev/null
if [ -r "$LIB" ]; then . "$LIB"; else
    AW_UTF8=0
    aw_setup_locale() { :; }; aw_palette() { :; }; aw_restore_palette() { :; }
    quiet_console() { dmesg -n 1 2>/dev/null || echo 1 > /proc/sys/kernel/printk 2>/dev/null || true; }
    vis_len()  { local s="${1:-}"; s="${s//\\Z?/}"; printf '%s' "${#s}"; }
    cz()       { local s="${1:-}"; printf '%s' "${s//\\/}"; }
    scr_cols() { tput cols 2>/dev/null || echo 80; }
    scr_rows() { tput lines 2>/dev/null || echo 25; }
    box_width() { echo 76; }
    center_block() { cat; }; center_lines() { cat; }
    banner_art() { printf 'A I R W A V E S   O S\n'; }
    aw_dialogrc() { printf 'use_colors = ON\nuse_shadow = OFF\n'; }
fi
aw_setup_locale

# Prefer the shipped shared theme (also used by airwaves-firstrun so the installer
# matches); fall back to recreating it on tmpfs from the library's canonical copy.
# The "hero" variant hides the outer box border (banner + status read as a clean
# borderless header) while the menu keeps its solid border.
SHARED_RC="/opt/airwaves/config/dialogrc"
SHARED_RC_HERO="/opt/airwaves/config/dialogrc-hero"
AWRC="/run/airwaves-tui.dialogrc"
AWRC_HERO=""
init_theme() {
    if [ -r "$SHARED_RC" ]; then AWRC="$SHARED_RC"; else
        aw_dialogrc > "$AWRC" 2>/dev/null || AWRC="/dev/null"
    fi
    if [ -r "$SHARED_RC_HERO" ]; then AWRC_HERO="$SHARED_RC_HERO"
    elif [ "$AWRC" != "/dev/null" ] && sed -e 's/^border_color .*/border_color = (BLACK,BLACK,OFF)/' \
            -e 's/^border2_color .*/border2_color = (BLACK,BLACK,OFF)/' "$AWRC" > /run/airwaves-tui-hero.dialogrc 2>/dev/null; then
        AWRC_HERO="/run/airwaves-tui-hero.dialogrc"
    else AWRC_HERO="$AWRC"; fi   # degrade to the bordered theme
}
# Run dialog with the branded theme + inline \Z colours (used everywhere).
dlg()  { DIALOGRC="$AWRC" dialog --colors "$@"; }
# Hero variant: borderless boxes (for the banner+status header stack).
dlgh() { DIALOGRC="$AWRC_HERO" dialog --colors "$@"; }

# ---- status helpers (all bounded so the menu never hangs) -------------------
api_up()    { curl -fsS -m3 "${API}/system/overview" >/dev/null 2>&1; }
api_get()   { curl -fsS -m6 "${API}$1" 2>/dev/null; }
api_post()  { curl -fsS -m20 -X POST "${API}$1" -H 'Content-Type: application/json' -d "${2:-}" 2>/dev/null; }
api_put()   { curl -fsS -m20 -X PUT  "${API}$1" -H 'Content-Type: application/json' -d "${2:-}" 2>/dev/null; }

primary_ip() {
    local f intf tmp
    for f in /sys/class/net/*; do
        intf="$(basename "$f")"
        case "$intf" in lo|docker0|br-*|veth*|dummy*) continue;; esac
        tmp="$(ip -4 addr show dev "$intf" 2>/dev/null | awk '/inet /{print $2}' | cut -d/ -f1 | head -1)"
        [ -n "$tmp" ] && { printf '%s' "$tmp"; return; }
    done
}
# Live = running off the USB installer, NOT an installed disk. With the live-boot
# (toram) image the root is an overlay/tmpfs in RAM, so we can't key off the root
# block device being removable; detect the live-boot environment instead. (Falls
# back to the removable-root check for any non-live-boot live media.)
is_live_boot() {
    grep -qw 'boot=live' /proc/cmdline 2>/dev/null && return 0
    [ -d /run/live/medium ] && return 0
    case "$(findmnt -no FSTYPE / 2>/dev/null)" in overlay|tmpfs|aufs) return 0 ;; esac
    local rd
    rd="$(lsblk -ndo pkname "$(findmnt -no SOURCE / 2>/dev/null)" 2>/dev/null)"
    [ -n "$rd" ] && [ "$(cat "/sys/block/${rd}/removable" 2>/dev/null || echo 0)" = "1" ]
}
is_live() { is_live_boot; }
# Bounded: on first boot dockerd is busy loading images, so an unbounded
# `docker inspect` could block the menu for minutes. Cap it.
svc() {
    local s
    s="$(timeout 3 docker inspect -f '{{if .State.Health}}{{.State.Health.Status}}{{else}}{{.State.Status}}{{end}}' "$1" 2>/dev/null)" || s="starting"
    printf '%s' "${s:-starting}"
}
release_var() { [ -f "$RELEASE" ] && awk -F= "/^$1=/{gsub(/\"/,\"\",\$2);print \$2}" "$RELEASE" 2>/dev/null; }

# ---- identity / status (split so the first-boot screen can skip docker) -----
# (banner_art lives in airwaves-tui-lib.sh.) Detail lines: slate labels, cream
# values, amber URLs. Centered by the caller; vis_len strips \Z so width math is
# correct. Values are sanitized (cz) so they can't inject a colour code.
id_lines() {
    local ver cn ch host ip mode
    ver="$(cz "$(release_var AIRWAVES_VERSION)")"; ver="${ver:-?}"
    cn="$(cz "$(release_var AIRWAVES_CODENAME)")"
    ch="$(cz "$(jq -r '.channel // "stable"' "$VERSIONS" 2>/dev/null || echo stable)")"
    host="$(cz "$(hostname 2>/dev/null)")"; ip="$(cz "$(primary_ip)")"
    if is_live; then mode="LIVE USB"; else mode="INSTALLED"; fi
    { printf '\Zb\Z7v%s\Zn' "$ver"; [ -n "$cn" ] && printf '  \Z6%s\Zn' "$cn"
      printf '   \Z6·\Zn   \Z3%s\Zn   \Z6·\Zn   \Z6channel\Zn \Zb\Z7%s\Zn\n' "$mode" "$ch"; }
    { printf '\Z6Host\Zn \Zb\Z7%s\Zn' "$host"; [ -n "$ip" ] && printf '     \Z6IP\Zn \Zb\Z7%s\Zn' "$ip"; printf '\n'; }
    { printf '\Z6Web UI\Zn \Z3http://%s.local\Zn' "$host"; [ -n "$ip" ] && printf '   \Z6/\Zn   \Z3http://%s\Zn' "$ip"; printf '\n'; }
}
# A service state -> coloured glyph + word: green Healthy / amber Starting /
# ember Down / slate Idle. Glyphs degrade to ASCII without a UTF-8 locale.
svc_token() {
    local ok go no id
    if [ "${AW_UTF8:-0}" = 1 ]; then ok='●'; go='◐'; no='●'; id='○'; else ok='*'; go='~'; no='x'; id='-'; fi
    case "$1" in
        healthy|running)               printf '\Zb\Z2%s Healthy\Zn' "$ok" ;;
        starting|created|restarting)   printf '\Zb\Z3%s\Zn \Z3Starting\Zn' "$go" ;;
        unhealthy|exited|dead|stopped) printf '\Zb\Z1%s Down\Zn' "$no" ;;
        *)                             printf '\Z6%s %s\Zn' "$id" "$(cz "$1")" ;;
    esac
}
# Services under a section header with dotted leaders (a block; caller centers it).
services_block() {
    local up ldr hdr hw r v maxw=0 pad; local -a rows=()
    up="$(uptime_str)"
    if [ "${AW_UTF8:-0}" = 1 ]; then ldr='············'; hdr='\Z6░▒▓\Zn\Zb\Z3 SERVICES \Zn\Z6▓▒░\Zn'; hw=16
    else ldr='............'; hdr='\Zb\Z3-- SERVICES --\Zn'; hw=14; fi
    rows+=("$(printf '\Z6%-8s %s\Zn %s' "manager" "$ldr" "$(svc_token "$(svc airwaves-manager)")")")
    rows+=("$(printf '\Z6%-8s %s\Zn %s' "gateway" "$ldr" "$(svc_token "$(svc airwaves-gateway)")")")
    rows+=("$(printf '\Z6%-8s %s\Zn \Zb\Z7%s\Zn' "uptime" "$ldr" "${up:-?}")")
    for r in "${rows[@]}"; do v="$(vis_len "$r")"; [ "$v" -gt "$maxw" ] && maxw="$v"; done
    pad=$(( (maxw - hw) / 2 )); [ "$pad" -lt 0 ] && pad=0
    printf '\n'                                  # margin above the SERVICES header
    printf '%*s%s\n' "$pad" '' "$hdr"            # header centred over the rows
    printf '%s\n' "${rows[@]}"
}
# (center_block, center_lines, scr_cols, scr_rows, box_width live in
# airwaves-tui-lib.sh — \Z-colour-aware and UTF-8-aware so coloured/glyph lines
# centre correctly.)

# Adaptive geometry for a centered two-box stack (a splash infobox on top + a
# menu or status box below). Grows the lower box to use spare vertical space (so
# all actions show and the layout breathes on big screens), shrinks to fit on
# small ones, and centers the whole stack. Echoes: "OX OY W TOPH BOTH LISTH".
#   $1 = splash text (its line count sets the top box height)
#   $2 = kind: "menu" (bottom is a --menu) or "info" (bottom is an --infobox)
#   $3 = count: menu item count, or info content line count
layout_stack() {
    local splash="$1" kind="$2" count="$3"
    local rows cols W topc toph chrome botmin both listh avail spare grow total oy ox
    # The backtitle occupies row 0 + a rule on row 1. Reserve a top margin so the
    # first box never butts against that rule (>=1 blank line; more on tall
    # screens via centering) and a small bottom margin for symmetry.
    local TOPM=3 BOTM=1
    rows="$(scr_rows)"; cols="$(scr_cols)"; W="$(box_width)"
    topc="$(printf '%s\n' "$splash" | wc -l | tr -d ' ')"
    toph=$(( topc + 2 ))                 # content + borders (splash carries its own blank-line padding)
    case "$kind" in
        menu) chrome=8 ;;                # borders + 2-line prompt + buttons + inter-spacing
        *)    chrome=2 ;;                # infobox: just borders
    esac
    botmin=$(( count + chrome ))
    avail=$(( rows - TOPM - BOTM ))      # vertical band for the whole stack
    both="$botmin"
    spare=$(( avail - toph - botmin ))
    if [ "$spare" -gt 0 ]; then
        grow=$(( spare / 2 )); [ "$grow" -gt 6 ] && grow=6   # cap so big screens don't get a cavernous box
        both=$(( both + grow ))
    fi
    total=$(( toph + both ))
    if [ "$total" -gt "$avail" ]; then  # small terminal: shrink the lower box
        both=$(( avail - toph )); [ "$both" -lt "$botmin" ] && both="$botmin"
        total=$(( toph + both ))
    fi
    listh=$(( both - chrome )); [ "$listh" -lt "$count" ] && listh="$count"
    oy=$(( TOPM + (avail - total) / 2 )); [ "$oy" -lt "$TOPM" ] && oy="$TOPM"
    ox=$(( (cols - W) / 2 )); [ "$ox" -lt 0 ] && ox=0
    echo "$ox $oy $W $toph $both $listh"
}

# Max splash content lines that leave room for the bottom box (so a small
# terminal sheds splash padding/banner instead of clipping the menu).
# $1 = kind (menu|info), $2 = bottom count (items or content lines).
splash_budget() {
    local rows avail chrome b
    rows="$(scr_rows)"; avail=$(( rows - 1 ))
    case "$1" in menu) chrome=8 ;; *) chrome=2 ;; esac
    b=$(( avail - $2 - chrome - 2 )); [ "$b" -lt 4 ] && b=4
    echo "$b"
}

# Assemble the splash (banner / details / optional Services) to fit within $2
# content lines, dropping decorative pieces first on small terminals and adding
# blank-line padding when there's room. $1 = inner width, $3 = 1 to include
# the Services block.
# Priority when space is tight: the banner is the hero (keep it), then the detail
# lines, then the Services block, then top padding. The banner carries a 2-line
# bottom margin so it never crowds the details. Services brings its own top margin.
BANNER_BMARGIN=2
build_splash() {
    local iw="$1" max="$2" with_svc="${3:-0}"
    local details services banner bn dn sn used=0 top=0 show_banner=0 show_svc=0
    details="$(id_lines | sed 's/^  *//' | center_lines "$iw")"
    dn="$(printf '%s\n' "$details" | wc -l | tr -d ' ')"
    banner="$(banner_art "$iw" | center_block "$iw")"
    bn="$(printf '%s\n' "$banner" | wc -l | tr -d ' ')"
    if [ "$with_svc" = 1 ]; then services="$(services_block | center_block "$iw")"; sn="$(printf '%s\n' "$services" | wc -l | tr -d ' ')"; else sn=0; fi
    used="$dn"
    [ "$max" -ge $(( used + bn + BANNER_BMARGIN )) ] && { show_banner=1; used=$(( used + bn + BANNER_BMARGIN )); }
    [ "$with_svc" = 1 ] && [ "$max" -ge $(( used + sn )) ] && { show_svc=1; used=$(( used + sn )); }
    [ "$max" -ge $(( used + 1 )) ] && top=1
    {
        [ "$top" = 1 ] && printf '\n'
        if [ "$show_banner" = 1 ]; then printf '%s\n' "$banner"; printf '%0.s\n' $(seq 1 "$BANNER_BMARGIN"); fi
        printf '%s\n' "$details"
        [ "$show_svc" = 1 ] && printf '%s\n' "$services"
    }
}

# ---- generic dialogs -------------------------------------------------------
msg()  { dlg --backtitle "${BT}" --title "$1" --msgbox "$2" "${3:-10}" "${4:-64}"; }
need_api() { api_up && return 0; msg "Manager unavailable" "\nThe manager service isn't responding, and this action requires it.\n\nTry again in a moment, or use 'Open a shell' to investigate." 11 62; return 1; }

# Warn the operator before a local (rescue) change that bypasses the manager.
# Returns 0 to proceed, 1 to cancel.
rescue_warn() {
    dlg --backtitle "${BT}" --title "Manager not running — rescue mode" --defaultno --yesno \
"\n\Zb\Z1Direct change — bypasses the manager.\Zn\n\nThe manager service isn't responding, so '\Z3$(cz "$1")\Zn' can't be set the normal way (through the manager, like the web UI).\n\nYou can configure it DIRECTLY now as a rescue:\n\n  \Z6•\Zn Changes apply to the host immediately.\n  \Z6•\Zn They BYPASS the manager and may differ from what the\n    manager shows once it comes back up.\n  \Z6•\Zn The manager reconciles/observes them on its next start.\n\nProceed with direct (rescue) configuration?" 18 70
}

# ---- Wi-Fi: API path + local nmcli rescue path -----------------------------
cfg_wifi_api() {
    dlg --backtitle "${BT}" --infobox "\nScanning for Wi-Fi networks..." 5 44
    local json rows=() ssid pw ssid_d
    json="$(api_get /wifi/scan)"
    [ -n "${json}" ] || { msg "Wi-Fi" "\nNo Wi-Fi interface found, or the scan failed.\n\n\Z6(Wired Ethernet needs no configuration.)\Zn" 11 62; return; }
    while IFS= read -r ssid; do [ -n "$ssid" ] && rows+=("$ssid" ""); done \
        < <(echo "${json}" | jq -r '.[].ssid // empty' 2>/dev/null | awk 'NF' | sort -u)
    [ "${#rows[@]}" -gt 0 ] || { msg "Wi-Fi" "\nNo networks found in range."; return; }
    ssid="$(dlg --backtitle "${BT}" --title "Wi-Fi networks" --menu "\nSelect a network:" 18 60 10 "${rows[@]}" 3>&1 1>&2 2>&3)" || return
    ssid_d="$(cz "$ssid")"   # display copy; raw ssid is kept for the API call
    pw="$(dlg --backtitle "${BT}" --title "Wi-Fi password" --insecure --passwordbox "\nPassword for \Z3${ssid_d}\Zn (blank for open):" 10 60 3>&1 1>&2 2>&3)" || return
    dlg --backtitle "${BT}" --infobox "\nConnecting to \Z3${ssid_d}\Zn..." 5 44
    if api_post /wifi/connect "{\"ssid\":\"${ssid}\",\"password\":\"${pw}\"}" >/dev/null; then
        msg "Wi-Fi" "\n\Zb\Z2Connect request sent\Zn for: \Z3${ssid_d}\Zn"
    else
        msg "Wi-Fi" "\n\Zb\Z1Failed to connect\Zn to \Z3${ssid_d}\Zn."
    fi
}
cfg_wifi_local() {
    command -v nmcli >/dev/null 2>&1 || { msg "Wi-Fi" "\nNetworkManager (nmcli) is not available, so a direct rescue connect isn't possible on this image."; return; }
    dlg --backtitle "${BT}" --infobox "\nScanning for Wi-Fi networks (direct / nmcli)..." 5 52
    local rows=() ssid pw out ssid_d
    # nmcli --terse escapes ':' as '\:' and '\' as '\\'; unescape via placeholder.
    while IFS= read -r ssid; do [ -n "$ssid" ] && rows+=("$ssid" ""); done \
        < <(nmcli -t -f SSID device wifi list --rescan yes 2>/dev/null \
            | sed -e 's/\\\\/\x01/g' -e 's/\\:/:/g' -e 's/\x01/\\/g' | awk 'NF' | sort -u)
    [ "${#rows[@]}" -gt 0 ] || { msg "Wi-Fi" "\nNo Wi-Fi networks found (or no Wi-Fi adapter).\n\n\Z6(Wired Ethernet needs no configuration.)\Zn" 11 62; return; }
    ssid="$(dlg --backtitle "${BT}" --title "Wi-Fi networks (rescue)" --menu "\nSelect a network:" 18 60 10 "${rows[@]}" 3>&1 1>&2 2>&3)" || return
    ssid_d="$(cz "$ssid")"   # display copy; raw ssid is kept for nmcli
    pw="$(dlg --backtitle "${BT}" --title "Wi-Fi password (rescue)" --insecure --passwordbox "\nPassword for \Z3${ssid_d}\Zn (blank for open):" 10 60 3>&1 1>&2 2>&3)" || return
    dlg --backtitle "${BT}" --infobox "\nConnecting to \Z3${ssid_d}\Zn (direct / nmcli)..." 5 52
    nmcli radio wifi on >/dev/null 2>&1 || true
    local rc
    if [ -n "${pw}" ]; then
        out="$(nmcli device wifi connect "${ssid}" password "${pw}" 2>&1)"; rc=$?
    else
        out="$(nmcli device wifi connect "${ssid}" 2>&1)"; rc=$?
    fi
    if [ "$rc" -eq 0 ]; then
        msg "Wi-Fi (rescue)" "\n\Zb\Z2Connected directly\Zn to: \Z3${ssid_d}\Zn\n\n\Z6This bypassed the manager. It will reconcile this\nconnection the next time it starts.\Zn" 11 64
    else
        msg "Wi-Fi (rescue)" "\n\Zb\Z1Failed to connect\Zn to \Z3${ssid_d}\Zn.\n\n\Z6$(cz "${out}")\Zn" 12 64
    fi
}
cfg_wifi() {
    if api_up; then cfg_wifi_api; else rescue_warn "Wi-Fi" && cfg_wifi_local; fi
}

# ---- hostname: API path + local hostnamectl rescue -------------------------
cfg_hostname() {
    local cur new
    if api_up; then
        cur="$(api_get /system/info | jq -r '.hostname // empty' 2>/dev/null)"; cur="${cur:-$(hostname)}"
        new="$(dlg --backtitle "${BT}" --title "Hostname" --inputbox "\nDevice hostname (letters, digits, hyphens):" 10 60 "${cur}" 3>&1 1>&2 2>&3)" || return
        [ -n "${new}" ] || { msg "Hostname" "\nHostname cannot be empty."; return; }
        if api_post /system/hostname "{\"hostname\":\"${new}\"}" >/dev/null; then
            msg "Hostname" "\nHostname set to: \Zb\Z7$(cz "${new}")\Zn"
        else
            msg "Hostname" "\n\Zb\Z1Failed to set hostname\Zn (the manager rejected it or is unavailable)."
        fi
    else
        rescue_warn "Hostname" || return
        cur="$(hostname)"
        new="$(dlg --backtitle "${BT}" --title "Hostname (rescue)" --inputbox "\nDevice hostname (letters, digits, hyphens):" 10 60 "${cur}" 3>&1 1>&2 2>&3)" || return
        [ -n "${new}" ] || { msg "Hostname" "\nHostname cannot be empty."; return; }
        if hostnamectl set-hostname "${new}" 2>/dev/null; then
            echo "${new}" > /etc/hostname 2>/dev/null || true
            systemctl restart avahi-daemon 2>/dev/null || true
            msg "Hostname (rescue)" "\nHostname set directly to: \Zb\Z7$(cz "${new}")\Zn\n\n\Z6This bypassed the manager.\Zn" 10 60
        else
            msg "Hostname (rescue)" "\n\Zb\Z1Failed to set hostname directly.\Zn"
        fi
    fi
}

# ---- update channel: API path + local .versions.json rescue ----------------
cfg_channel() {
    local cur new
    cur="$(jq -r '.channel // "stable"' "$VERSIONS" 2>/dev/null || echo stable)"
    new="$(dlg --backtitle "${BT}" --title "Update channel" --default-item "${cur}" \
        --menu "\nCurrent: \Zb\Z7$(cz "${cur}")\Zn\n\nChoose the update channel:" 14 60 3 \
        stable "Tested releases (recommended)" \
        beta   "Pre-release candidates" \
        dev    "Latest development builds" 3>&1 1>&2 2>&3)" || return
    if api_up; then
        if api_post /system/update/channel "{\"channel\":\"${new}\"}" >/dev/null; then
            msg "Update channel" "\nChannel set to: ${new}\n\nUse Upgrade to apply the latest on this channel."
        else
            msg "Update channel" "\nFailed to set channel."
        fi
    else
        rescue_warn "Update channel" || return
        local tmp
        tmp="$(jq -c --arg c "${new}" '.channel = $c' "$VERSIONS" 2>/dev/null)"
        if [ -n "${tmp}" ] && printf '%s\n' "${tmp}" > "${VERSIONS}" 2>/dev/null; then
            msg "Update channel (rescue)" "\nChannel set directly to: ${new}\n\nThis bypassed the manager." 10 60
        else
            msg "Update channel (rescue)" "\nFailed to write ${VERSIONS}."
        fi
    fi
}

# ---- password (always local: PAM) ------------------------------------------
cfg_password() {
    clear
    echo "== Change the 'airwaves' user password =="
    echo
    passwd airwaves || true
    echo
    read -r -p "Also change the root password? [y/N] " a
    case "$a" in y|Y) passwd root || true;; esac
    echo; read -r -p "Press ENTER to return to the menu..." _
}

# ---- Airframes feeder token (manager only) ---------------------------------
cfg_airframes() {
    need_api || return
    local tok cfg
    tok="$(dlg --backtitle "${BT}" --title "Airframes feeder token (optional)" --insecure --passwordbox \
        "\nPaste your Airframes.io feeder token/API key to share data with the\nAirframes network. Leave blank to skip.\n\n(Account username/password login is coming in a later update.)" 13 66 3>&1 1>&2 2>&3)" || return
    [ -n "${tok}" ] || return
    cfg="$(api_get /config)"; [ -n "${cfg}" ] || { msg "Airframes" "\nCould not read current config."; return; }
    cfg="$(echo "${cfg}" | jq -c --arg k "${tok}" '.api_key = $k' 2>/dev/null)"
    if [ -n "${cfg}" ] && api_put /config "${cfg}" >/dev/null; then
        msg "Airframes" "\nAirframes feeder token saved."
    else
        msg "Airframes" "\nFailed to save the token."
    fi
}

configuration_menu() {
    local hint c
    if api_up; then hint="applied via the manager, like the web UI"; else hint="MANAGER DOWN — Wi-Fi/hostname/channel offer a direct rescue"; fi
    while true; do
        c="$(dlg --backtitle "${BT}" --title "Configuration" --cancel-label "Back" \
            --menu "\nConfigure this device (${hint}):" 16 70 7 \
            hostname  "Change hostname" \
            wifi      "Configure wireless (Wi-Fi)" \
            channel   "Change update channel" \
            password  "Change password" \
            airframes "Airframes feeder token (optional)" \
            3>&1 1>&2 2>&3)" || return
        case "$c" in
            hostname)  cfg_hostname ;;
            wifi)      cfg_wifi ;;
            channel)   cfg_channel ;;
            password)  cfg_password ;;
            airframes) cfg_airframes ;;
        esac
    done
}

# ---- update / repair (manager-driven) --------------------------------------
update_gauge() {
    (
        local p pct phase state
        for _ in $(seq 1 1200); do
            p="$(curl -fsS -m4 "${API}/system/update/progress" 2>/dev/null)"
            pct="$(printf '%s' "$p" | jq -r '.percent // 0' 2>/dev/null || echo 0)"
            phase="$(printf '%s' "$p" | jq -r '.phase // "working"' 2>/dev/null || echo working)"
            state="$(printf '%s' "$p" | jq -r '.state // "running"' 2>/dev/null || echo running)"
            echo "XXX"; echo "${pct:-0}"; printf '%s\nStep: \Zb\Z3%s\Zn\n' "$1" "$(cz "$phase")"; echo "XXX"
            case "$state" in success|failed|rolled_back) break;; esac
            sleep 2
        done
        echo 100
    ) | dlg --backtitle "$BT" --title "$1" --gauge "\nStarting..." 10 64 0
}
apply_update() {   # $1 = upgrade | repair
    need_api || return
    if [ "$1" = repair ]; then
        curl -fsS -m10 -X POST "${API}/system/update/refresh" >/dev/null 2>&1
    else
        curl -fsS -m10 -X POST "${API}/system/update/apply" -H 'Content-Type: application/json' \
            -d '{"components":["manager","gateway","compose","catalog"]}' >/dev/null 2>&1
    fi
    update_gauge "${1^} in progress"
    local prog st err
    prog="$(curl -fsS -m4 "${API}/system/update/progress" 2>/dev/null)"
    st="$(printf '%s' "$prog" | jq -r '.state // "unknown"' 2>/dev/null || echo unknown)"
    if [ "$st" = success ]; then
        msg "${1^}" "\n\Zb\Z2${1^} completed successfully.\Zn" 8 50
    else
        err="$(printf '%s' "$prog" | jq -r '.error // "see /var/log/airwaves-update.log"' 2>/dev/null)"
        msg "${1^} did not complete" "\n\Z6State:\Zn $(cz "${st}")\n\n$(cz "${err}")" 12 64
    fi
}
open_shell() {
    aw_restore_palette   # hand the plain shell the console's default palette
    clear
    echo "Airwaves OS shell — type 'exit' to return to the console menu."; echo
    AIRWAVES_TUI_SHELL=1 bash -l || true
    aw_palette           # re-apply the brand palette when returning to the menu
}

# ---- first-boot status screen (#20) ----------------------------------------
# While first-boot init is still running, show what it's doing instead of a
# half-working menu. airwaves-init logs each step to its journal; we surface the
# latest line. The marker is removed when init finalizes, so this falls through
# to the menu automatically. If init FAILED, we skip this and show the menu so
# the operator can open a shell / repair.
first_boot_active() {
    [ -f "$FIRSTRUN_MARKER" ] && ! systemctl is-failed --quiet airwaves-init.service 2>/dev/null
}
first_boot_screen() {
    local step splash
    step="$(journalctl -u airwaves-init.service -o cat --no-pager 2>/dev/null | awk 'NF' | tail -1)"
    step="${step#\[airwaves-init\] }"
    [ -n "$step" ] || step="Starting first-boot setup..."
    step="$(cz "$step")"
    # Banner + details form the borderless header (splash); the first-boot status
    # goes in a HAND-DRAWN framed box below (so it reads as a proper card even
    # though the hero infobox is borderless), with a blank top-margin row above it.
    # The amber ▸ cursor + step is the one moving accent; the rest is calm slate.
    local W iw splash status fb oy ox toph both lh botc maxs cur
    W="$(box_width)"; iw=$(( W - 2 ))
    if [ "${AW_UTF8:-0}" = 1 ]; then cur='▸'; else cur='>'; fi
    status="$( {
        printf '\Zb\Z7First boot — preparing your device.\Zn \Z6This happens only once.\Zn\n'
        printf '\n'
        printf '\Zb\Z3%s\Zn \Zb\Z3%s\Zn\n' "${cur}" "${step}"
        printf '\n'
        printf '\Z6Loading the app stack from the on-board copy (no network needed).\Zn\n'
        printf '\Z6The console menu appears automatically when ready.\Zn\n'
    } )"
    # Frame width W-6 fits inside the infobox text area (dialog reserves a border
    # + margin on each side); wider frames wrap and shatter the box-drawing.
    fb="$(printf '%s\n' "${status}" | framebox "$(( W - 6 ))" "Setting up Airwaves OS")"
    fb="$(printf '\n%s\n' "${fb}")"                 # blank top-margin row above the box
    botc="$(printf '%s\n' "${fb}" | wc -l | tr -d ' ')"
    maxs="$(splash_budget info "${botc}")"
    splash="$(build_splash "${iw}" "${maxs}" 0)"    # banner + details (no services here)
    read -r ox oy W toph both lh < <(layout_stack "${splash}" info "${botc}")
    # Borderless (dlgh) header; the framed status box draws its own border.
    # --colors is per-widget in --and-widget chains, so repeat it before the box.
    dlgh --backtitle "${BT}" --no-collapse --keep-window \
        --begin "${oy}" "${ox}" --no-shadow --infobox "${splash}" "${toph}" "${W}" \
        --and-widget --colors --no-collapse --keep-window --no-shadow \
        --begin "$((oy + toph))" "${ox}" --infobox "${fb}" "${both}" "${W}"
    sleep 2
}

# ---- unattended / self-install (armed by airwaves-preconfig from AWCFG) -----
# Perform a config-driven install with a countdown the operator can cancel. On
# success, power off (USB) or reboot (SD self-install). On cancel/failure, remove
# the trigger and fall back to the menu. The actual erase is gated by the
# installer's AIRWAVES_INSTALL_APPLY=1, set only after this confirmation.
run_unattended_install() {
    local target ab cfg mode post args rc state err
    target="$(jq -r '.target // empty' "$TRIGGER" 2>/dev/null)"
    ab="$(jq -r '.ab // false' "$TRIGGER" 2>/dev/null)"
    cfg="$(jq -r '.config // empty' "$TRIGGER" 2>/dev/null)"
    mode="$(jq -r '.mode // empty' "$TRIGGER" 2>/dev/null)"
    post="$(jq -r '.post_install // "poweroff"' "$TRIGGER" 2>/dev/null)"
    [ -n "$target" ] || { rm -f "$TRIGGER"; return 1; }

    # Defense in depth: re-validate the target is an available internal disk.
    if ! "$INSTALL" --list-json 2>/dev/null | jq -e --arg d "$target" 'any(.[]; .device==$d)' >/dev/null 2>&1; then
        rm -f "$TRIGGER"
        msg "Unattended install" "\nConfigured target ${target} is not an available internal disk.\n\nUsing the menu instead." 11 62
        return 1
    fi

    dlg --backtitle "$BT" --title "Unattended install (from AWCFG config)" --pause \
        "\nThe config partition requests an UNATTENDED install to:\n\n    \Zb\Z7$(cz "${target}")\Zn\n\nThis will \Zb\Z1ERASE ALL DATA\ZB\Zn on \Zb\Z7$(cz "${target}")\Zn.\n\Z6Cancel now to use the menu instead.\Zn" 15 64 8 \
        || { rm -f "$TRIGGER"; return 1; }

    rm -f "$ISTATUS" 2>/dev/null || true
    args=(--target "$target")
    [ "$ab" = "true" ] && args+=(--ab)
    [ -n "$cfg" ] && [ -f "$cfg" ] && args+=(--config "$cfg")
    AIRWAVES_INSTALL_APPLY=1 "$INSTALL" "${args[@]}" >/var/log/airwaves-install.log 2>&1 &
    local pid=$!
    (
        local pct phase
        while kill -0 "$pid" 2>/dev/null; do
            pct="$(jq -r '.percent // 0' "$ISTATUS" 2>/dev/null || echo 0)"
            phase="$(jq -r '.phase // "working"' "$ISTATUS" 2>/dev/null || echo working)"
            echo "XXX"; echo "${pct:-0}"; printf 'Installing to \Zb\Z7%s\Zn\nStep: \Zb\Z3%s\Zn\n\Z6Keep the power connected.\Zn\n' "$(cz "$target")" "$(cz "$phase")"; echo "XXX"
            sleep 2
        done
        echo 100
    ) | dlg --backtitle "$BT" --title "Unattended install" --gauge "\nPreparing..." 12 64 0
    wait "$pid"; rc=$?
    state="$(jq -r '.state // "unknown"' "$ISTATUS" 2>/dev/null || echo unknown)"

    if [ "$rc" -eq 0 ] && [ "$state" = "success" ]; then
        rm -f "$TRIGGER"
        # Anti-loop: a self-install from a fixed SD/eMMC marks the SOURCE done so a
        # re-boot from it won't reinstall.
        [ "$mode" = "sd-self-install" ] && touch /opt/airwaves/.initialized 2>/dev/null || true
        systemctl stop airwaves-containers.service 2>/dev/null || true
        docker compose -f /etc/airwaves/docker-compose.yml down --timeout 10 2>/dev/null || true
        sync; sync
        if [ "$post" = "reboot" ]; then
            dlg --backtitle "$BT" --title "Installed" --infobox "\n\Zb\Z2Install complete.\Zn Rebooting into \Zb\Z7$(cz "${target}")\Zn..." 7 56
            sleep 2; clear; systemctl reboot
        else
            dlg --backtitle "$BT" --title "Installed" --msgbox "\n\Zb\Z2Install complete.\Zn\n\nThe device will \Z3POWER OFF\Zn. Remove the install media,\nthen power on to boot \Zb\Z7$(cz "${target}")\Zn." 12 64
            clear; echo "Powering off..."; mount -o remount,ro / 2>/dev/null || true; systemctl poweroff
        fi
        return 0
    fi

    err="$(jq -r '.error // "see /var/log/airwaves-install.log"' "$ISTATUS" 2>/dev/null)"
    rm -f "$TRIGGER"
    msg "Unattended install failed" "\n\Z6State:\Zn $(cz "${state}")\n\n$(cz "${err}")\n\n\Z6Using the interactive menu.\Zn" 13 66
    return 1
}

command -v dialog >/dev/null 2>&1 || { echo "dialog not available; opening a shell."; exec bash -l; }
quiet_console
aw_palette        # remap the 16 console slots to the night-watch brand colours
init_theme

while true; do
    # Config-driven install armed by airwaves-preconfig (AWCFG). Do it first.
    if [ -f "$TRIGGER" ]; then run_unattended_install; continue; fi
    # First-boot: show progress until init finishes (or fails).
    if first_boot_active; then first_boot_screen; continue; fi

    items=()
    if is_live; then
        items+=( install "Install Airwaves OS to an internal disk" )
    else
        items+=( config  "Configuration (hostname, Wi-Fi, channel, password)" )
    fi
    items+=( upgrade  "Upgrade to the latest for this channel" )
    items+=( repair   "Repair (re-pull + recreate the app stack)" )
    items+=( shell    "Open a shell" )
    items+=( reboot   "Reboot" )
    items+=( poweroff "Power off" )

    # Banner box (kept on screen) above the action menu (#22). --keep-window
    # retains the infobox while the menu takes input; --begin stacks them. The
    # banner is centered as a block; the detail/status lines are each centered.
    # Banner (block-centered) + details (line-centered) + a vertical Services
    # list (block-centered so its column stays aligned).
    # Adaptive, centered, padded layout: splash on top, action menu below sized to
    # show every action and grow/shrink with the terminal.
    W="$(box_width)"; iw=$(( W - 2 ))
    nitems=$(( ${#items[@]} / 2 ))
    maxs="$(splash_budget menu "${nitems}")"
    splash="$(build_splash "${iw}" "${maxs}" 1)"   # banner + details + Services
    read -r ox oy W toph both lh < <(layout_stack "${splash}" menu "${nitems}")
    # dlgh: the header infobox is borderless; the menu (menubox_border) stays boxed.
    choice="$(dlgh --backtitle "${BT}" --no-collapse --keep-window \
        --begin "${oy}" "${ox}" --no-shadow --infobox "${splash}" "${toph}" "${W}" \
        --and-widget --colors --keep-window --no-shadow --no-cancel \
        --begin "$((oy + toph))" "${ox}" --title "Airwaves OS Console" \
        --menu "\n  \Z6Select an action:\Zn" "${both}" "${W}" "${lh}" "${items[@]}" \
        3>&1 1>&2 2>&3)" || { sleep 1; continue; }

    case "$choice" in
        install)  clear; "$FIRSTRUN" --install || true ;;
        config)   configuration_menu ;;
        upgrade)  apply_update upgrade ;;
        repair)   dlg --backtitle "$BT" --title "Repair" --defaultno \
                      --yesno "\nRepair re-pulls and recreates the app containers\n(no version change).\n\n\Z6Continue?\Zn" 10 62 \
                      && apply_update repair ;;
        shell)    open_shell ;;
        reboot)   dlg --backtitle "$BT" --title "Reboot" --defaultno --yesno "\n\Z3Reboot\Zn now?" 7 40 && { clear; systemctl reboot; } ;;
        poweroff) dlg --backtitle "$BT" --title "Power off" --defaultno --yesno "\n\Z1Power off\Zn now?" 7 40 && { clear; systemctl poweroff; } ;;
    esac
done
