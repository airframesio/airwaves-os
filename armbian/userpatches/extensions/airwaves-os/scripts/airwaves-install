#!/bin/bash
#
# airwaves-install — install the running (live USB / SD) Airwaves OS system onto
# an internal disk (NVMe / eMMC / SATA / USB-SSD). Reuses Armbian's proven
# per-platform disk approach but replaces the interactive dialog UI with a
# structured status.json (same shape as airwaves-update) so the console wizard,
# web UI, and any other front-end can render branded, structured progress.
#
# Supported platforms (auto-detected):
#   - uefi-x86   : GPT + FAT32 ESP + ext4 root, grub-install in a chroot.
#   - uboot      : Rockchip rk3588 (Rock 5B, Orange Pi 5) and other u-boot ARM
#                  boards. ext4 root starting at 16MiB; the bootloader is written
#                  to raw sectors via Armbian's on-device write_uboot_platform.
#   - rpi        : Raspberry Pi (bcm2711). FAT32 /boot/firmware + ext4 root; the
#                  GPU firmware boots the kernel directly (no grub/u-boot).
#
# SAFETY: destructive disk operations only run when AIRWAVES_INSTALL_APPLY=1.
# Without it, the script performs all preflight checks and prints the plan
# (dry-run). Front-ends pass APPLY=1 only after explicit user confirmation.
#
# Usage:
#   airwaves-install --list-json                 # list candidate target disks (JSON)
#   airwaves-install --target /dev/nvme0n1       # dry-run plan for that disk
#   AIRWAVES_INSTALL_APPLY=1 airwaves-install --target /dev/nvme0n1   # real install
#
set -uo pipefail

STATUS_DIR="/etc/airwaves/install"
STATUS="${STATUS_DIR}/status.json"
LOG_TMP="$(mktemp /tmp/airwaves-install.log.XXXXXX)"
STATUS_LOG_LINES=200

STATE="running"
PHASE="preflight"
PERCENT=0
ERROR=""
REBOOT_REQUIRED="false"
STARTED_AT="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
TARGET=""
APPLY="${AIRWAVES_INSTALL_APPLY:-0}"

# Set by detect_platform / the partition step.
PLATFORM=""
ARCH=""
BOARD=""
BOARDFAMILY=""
ROOT_DEV=""    # target root partition device
BOOT_DEV=""    # target ESP/firmware partition device (empty for uboot)
TMP=""

mkdir -p "${STATUS_DIR}"

log() {
    local line
    line="[$(date -u +%H:%M:%S)] $*"
    echo "${line}" >&2
    echo "${line}" >> "${LOG_TMP}"
}

write_status() {
    local finished="${1:-}"
    local finished_field="null"
    [ -n "${finished}" ] && finished_field="\"${finished}\""
    local err_field="null"
    [ -n "${ERROR}" ] && err_field="$(jq -Rn --arg e "${ERROR}" '$e')"
    jq -Rn \
        --arg state "${STATE}" \
        --arg phase "${PHASE}" \
        --argjson percent "${PERCENT}" \
        --argjson reboot "${REBOOT_REQUIRED}" \
        --arg started "${STARTED_AT}" \
        --arg target "${TARGET}" \
        --slurpfile loglines <(tail -n "${STATUS_LOG_LINES}" "${LOG_TMP}" 2>/dev/null | jq -R .) \
        "{
            state: \$state,
            phase: \$phase,
            percent: \$percent,
            target: \$target,
            reboot_required: \$reboot,
            error: ${err_field},
            started_at: \$started,
            finished_at: ${finished_field},
            log: \$loglines
        }" > "${STATUS}.tmp" 2>/dev/null && mv "${STATUS}.tmp" "${STATUS}"
}

phase() {
    PHASE="$1"
    PERCENT="${2:-$PERCENT}"
    log "==> ${PHASE} (${PERCENT}%)"
    write_status
}

fail() {
    STATE="failed"
    ERROR="$1"
    log "ERROR: ${ERROR}"
    write_status "$(date -u +%Y-%m-%dT%H:%M:%SZ)"
    exit 1
}

# ---- platform detection ----------------------------------------------------

detect_platform() {
    ARCH="$(uname -m)"
    if [ -r /etc/armbian-release ]; then
        BOARD="$(awk -F= '/^BOARD=/{gsub(/"/,"",$2);print $2}' /etc/armbian-release 2>/dev/null)"
        BOARDFAMILY="$(awk -F= '/^BOARDFAMILY=/{gsub(/"/,"",$2);print $2}' /etc/armbian-release 2>/dev/null)"
    fi

    # x86 + UEFI: the live-USB installer target.
    if [ "${ARCH}" = "x86_64" ] && [ -d /sys/firmware/efi ]; then
        PLATFORM="uefi-x86"; return 0
    fi
    # Raspberry Pi: GPU firmware boots from a FAT partition (no u-boot/grub).
    case "${BOARDFAMILY}" in bcm27*|bcm28*) PLATFORM="rpi"; return 0 ;; esac
    case "${BOARD}" in rpi*|raspberrypi*) PLATFORM="rpi"; return 0 ;; esac
    # Rockchip and other u-boot boards: bootloader lives in raw sectors and is
    # written by the on-device write_uboot_platform (from the u-boot package).
    if [ -f /usr/lib/u-boot/platform_install.sh ]; then PLATFORM="uboot"; return 0; fi
    case "${BOARDFAMILY}" in rockchip*|sunxi*|meson*|rk*) PLATFORM="uboot"; return 0 ;; esac

    PLATFORM="unknown"
}

# ---- source / target discovery (mirrors armbian-install) -------------------

discover_source() {
    ROOT_UUID="$(sed -e 's/^.*root=//' -e 's/ .*$//' < /proc/cmdline)"
    ROOT_PART="$(blkid | tr -d '":' | grep -w "${ROOT_UUID#UUID=}" | awk '{print $1}' | head -1)"
    [ -z "${ROOT_PART}" ] && ROOT_PART="$(findmnt -no SOURCE / 2>/dev/null)"
    SOURCE_DISK_NAME="$(lsblk -ndo pkname "${ROOT_PART}" 2>/dev/null)"
    SOURCE_DISK="/dev/${SOURCE_DISK_NAME}"
}

# Candidate internal target disks: real disks, not the source (boot) device, not
# optical/virtual. Removable disks are skipped EXCEPT that the source is always
# skipped regardless. One JSON object per disk.
list_targets_json() {
    discover_source
    local rows="[]"
    # MODEL is read LAST because it is frequently empty (virtio, some NVMe); a
    # blank middle column would shift positional fields and drop the disk.
    while read -r name rm type size model; do
        [ "${type}" != "disk" ] && continue
        [ "${rm}" = "1" ] && continue                 # skip removable (the USB/SD)
        [ "/dev/${name}" = "${SOURCE_DISK}" ] && continue
        # Skip optical, virtual, and pseudo block devices (never install targets).
        case "${name}" in sr*|loop*|ram*|zram*|fd*|dm-*|md*|nbd*) continue;; esac
        rows="$(jq -c \
            --arg dev "/dev/${name}" \
            --arg size "${size}" \
            --arg model "${model}" \
            '. + [{device:$dev, size:$size, model:($model|gsub("^ +| +$";""))}]' \
            <<<"${rows}")"
    done < <(lsblk -dno NAME,RM,TYPE,SIZE,MODEL)
    echo "${rows}"
}

# ---- preflight guards ------------------------------------------------------

preflight() {
    phase "preflight" 5
    command -v jq >/dev/null     || fail "jq is required"
    command -v parted >/dev/null || fail "parted is required"
    command -v rsync >/dev/null  || fail "rsync is required"
    command -v mkfs.ext4 >/dev/null || fail "mkfs.ext4 not found (e2fsprogs missing from image)"

    detect_platform
    log "Platform: ${PLATFORM} (arch=${ARCH} board=${BOARD:-?} family=${BOARDFAMILY:-?})"
    case "${PLATFORM}" in
        uefi-x86)
            command -v mkfs.vfat >/dev/null || fail "mkfs.vfat not found (dosfstools missing from image)"
            ;;
        rpi)
            command -v mkfs.vfat >/dev/null || fail "mkfs.vfat not found (dosfstools missing from image)"
            mountpoint -q /boot/firmware || [ -d /boot/firmware ] \
                || fail "/boot/firmware not present; cannot stage Raspberry Pi boot files"
            ;;
        uboot)
            [ -f /usr/lib/u-boot/platform_install.sh ] \
                || fail "u-boot platform script (/usr/lib/u-boot/platform_install.sh) missing; cannot install bootloader"
            ;;
        *)
            fail "Unsupported platform for install (arch=${ARCH}, family=${BOARDFAMILY:-unknown}). Supported: x86 UEFI, Rockchip/u-boot ARM, Raspberry Pi."
            ;;
    esac

    [ -n "${TARGET}" ] || fail "No target disk specified"
    [ -b "${TARGET}" ] || fail "Target ${TARGET} is not a block device"

    discover_source
    [ "${TARGET}" = "${SOURCE_DISK}" ] && fail "Refusing to install onto the source/boot device ${TARGET}"

    # Target must be a whole disk, not a partition.
    local ttype
    ttype="$(lsblk -ndo TYPE "${TARGET}")"
    [ "${ttype}" = "disk" ] || fail "Target ${TARGET} is not a whole disk (type=${ttype})"

    # Target must not have mounted partitions.
    if lsblk -nro MOUNTPOINT "${TARGET}" | grep -q .; then
        fail "Target ${TARGET} has mounted partitions; refusing to proceed"
    fi

    log "Source (live) disk: ${SOURCE_DISK}"
    log "Target disk:        ${TARGET}"
    if [ "${APPLY}" != "1" ]; then
        log "DRY-RUN: set AIRWAVES_INSTALL_APPLY=1 to perform the install."
    fi
}

# partition suffix: nvme0n1 -> p1, mmcblk0 -> p1, sda -> 1
part() { case "$1" in *[0-9]) echo "$1p$2";; *) echo "$1$2";; esac; }

# Wait for the kernel + udev to create the given partition device nodes after
# (re)partitioning. parted + udev can lag; mkfs against a missing node fails.
settle_parts() {
    partprobe "${TARGET}" >>"${LOG_TMP}" 2>&1 || true
    command -v udevadm >/dev/null && udevadm settle --timeout=10 >>"${LOG_TMP}" 2>&1 || true
    local n d ok
    for n in $(seq 1 15); do
        ok=1
        for d in "$@"; do [ -b "${d}" ] || ok=0; done
        [ "${ok}" = "1" ] && return 0
        sleep 1
        partprobe "${TARGET}" >>"${LOG_TMP}" 2>&1 || true
    done
    for d in "$@"; do
        [ -b "${d}" ] || fail "partition ${d} never appeared: $(tail -n3 "${LOG_TMP}" 2>/dev/null)"
    done
}

# ---- partition + format: per platform --------------------------------------

partition_x86() {  # GPT + FAT32 ESP(512MiB) + ext4 root
    phase "partitioning" 15
    BOOT_DEV="$(part "${TARGET}" 1)"; ROOT_DEV="$(part "${TARGET}" 2)"
    if [ "${APPLY}" != "1" ]; then
        log "[dry-run] wipefs ${TARGET}; gpt; ESP(${BOOT_DEV},fat32,512MiB); root(${ROOT_DEV},ext4,rest)"
        return 0
    fi
    wipefs -a "${TARGET}" >>"${LOG_TMP}" 2>&1
    parted -s "${TARGET}" -- mklabel gpt >>"${LOG_TMP}" 2>&1 || fail "parted mklabel failed"
    parted -s "${TARGET}" -- mkpart "ESP" fat32 1MiB 513MiB >>"${LOG_TMP}" 2>&1 || fail "parted ESP failed"
    parted -s "${TARGET}" -- set 1 esp on >>"${LOG_TMP}" 2>&1
    parted -s "${TARGET}" -- mkpart "airwaves-root" ext4 513MiB 100% >>"${LOG_TMP}" 2>&1 || fail "parted root failed"
    settle_parts "${BOOT_DEV}" "${ROOT_DEV}"

    phase "formatting" 25
    # FAT volume labels are limited to 11 characters.
    mkfs.vfat -F32 -n AIRWAVES "${BOOT_DEV}" >>"${LOG_TMP}" 2>&1 || fail "mkfs.vfat failed: $(tail -n3 "${LOG_TMP}" 2>/dev/null)"
    mkfs.ext4 -qF -L airwaves-root "${ROOT_DEV}" >>"${LOG_TMP}" 2>&1 || fail "mkfs.ext4 failed: $(tail -n3 "${LOG_TMP}" 2>/dev/null)"
}

partition_uboot() {  # GPT + ext4 root starting at 16MiB (raw sectors hold u-boot)
    phase "partitioning" 15
    BOOT_DEV=""; ROOT_DEV="$(part "${TARGET}" 1)"
    if [ "${APPLY}" != "1" ]; then
        log "[dry-run] wipefs ${TARGET}; gpt; root(${ROOT_DEV},ext4,16MiB→rest); u-boot to raw sectors of ${TARGET}"
        return 0
    fi
    wipefs -a "${TARGET}" >>"${LOG_TMP}" 2>&1
    parted -s "${TARGET}" -- mklabel gpt >>"${LOG_TMP}" 2>&1 || fail "parted mklabel failed"
    # Partition 1 starts at 16MiB, matching Armbian's OFFSET, leaving the 0–16MiB
    # region for the raw u-boot blobs written by write_uboot_platform.
    parted -s "${TARGET}" -- mkpart "armbi_root" ext4 16MiB 100% >>"${LOG_TMP}" 2>&1 || fail "parted root failed"
    settle_parts "${ROOT_DEV}"

    phase "formatting" 25
    mkfs.ext4 -qF -L armbi_root "${ROOT_DEV}" >>"${LOG_TMP}" 2>&1 || fail "mkfs.ext4 failed: $(tail -n3 "${LOG_TMP}" 2>/dev/null)"
}

partition_rpi() {  # GPT + FAT32 /boot/firmware(512MiB) + ext4 root
    phase "partitioning" 15
    BOOT_DEV="$(part "${TARGET}" 1)"; ROOT_DEV="$(part "${TARGET}" 2)"
    if [ "${APPLY}" != "1" ]; then
        log "[dry-run] wipefs ${TARGET}; gpt; firmware(${BOOT_DEV},fat32,512MiB,RPICFG); root(${ROOT_DEV},ext4,rest)"
        return 0
    fi
    wipefs -a "${TARGET}" >>"${LOG_TMP}" 2>&1
    parted -s "${TARGET}" -- mklabel gpt >>"${LOG_TMP}" 2>&1 || fail "parted mklabel failed"
    parted -s "${TARGET}" -- mkpart "RPICFG" fat32 1MiB 513MiB >>"${LOG_TMP}" 2>&1 || fail "parted firmware failed"
    # The Raspberry Pi firmware boots a FAT data partition directly; the ESP flag
    # is intentionally NOT set (matches Armbian, which clears it for Pi 3/4).
    parted -s "${TARGET}" -- mkpart "armbi_root" ext4 513MiB 100% >>"${LOG_TMP}" 2>&1 || fail "parted root failed"
    settle_parts "${BOOT_DEV}" "${ROOT_DEV}"

    phase "formatting" 25
    mkfs.vfat -F32 -n RPICFG "${BOOT_DEV}" >>"${LOG_TMP}" 2>&1 || fail "mkfs.vfat failed: $(tail -n3 "${LOG_TMP}" 2>/dev/null)"
    mkfs.ext4 -qF -L armbi_root "${ROOT_DEV}" >>"${LOG_TMP}" 2>&1 || fail "mkfs.ext4 failed: $(tail -n3 "${LOG_TMP}" 2>/dev/null)"
}

# ---- copy rootfs (rsync with live progress) --------------------------------
# Shared across platforms: mounts the target root and rsyncs the running rootfs.
# rsync -x stays on one filesystem, so separate mounts (the ESP/firmware on the
# source, pseudo-fs) are not descended into; per-platform boot files are staged
# in the bootloader step.

copy_rootfs() {
    phase "copying-rootfs" 30
    TMP="$(mktemp -d /mnt/airwaves-install.XXXXXX)"

    cat > /tmp/airwaves-install-exclude <<'EOF'
/dev/*
/proc/*
/sys/*
/tmp/*
/run/*
/mnt/*
/media/*
/lost+found
/var/log.hdd/*
/swapfile
/etc/airwaves/install/*
# Don't copy the live Docker/containerd store: it's being written while we
# rsync (docker is running), so the copy is inconsistent and the target's
# content store ends up with dangling layer references ("blob not found").
# The installed system pulls the app images fresh on first boot, same as the
# live USB does.
/var/lib/docker/*
/var/lib/containerd/*
/var/lib/docker.hdd/*
EOF

    if [ "${APPLY}" != "1" ]; then
        log "[dry-run] rsync / -> ${ROOT_DEV} (excludes pseudo-fs); would stream progress 30→80%"
        PERCENT=80; write_status
        rmdir "${TMP}" 2>/dev/null || true
        return 0
    fi

    mount "${ROOT_DEV}" "${TMP}" || fail "mount ${ROOT_DEV} failed"
    echo "${TMP}" >/tmp/airwaves-install-mnt

    local todo
    todo="$(rsync -anx --delete --stats --exclude-from=/tmp/airwaves-install-exclude / "${TMP}" 2>/dev/null | awk '/Number of files:/{gsub(/[.,]/,"",$4); print $4; exit}')"
    [ -z "${todo}" ] && todo=1
    local progress=/tmp/airwaves-install-progress; echo 0 >"${progress}"; local done=/tmp/airwaves-install-done; echo no >"${done}"
    {
        rsync -ax --delete --exclude-from=/tmp/airwaves-install-exclude / "${TMP}" \
            | stdbuf -oL awk -v todo="${todo}" '{p=int(50*NR/todo); if(p>50)p=50; print p; fflush()}' > "${progress}"
        echo "${PIPESTATUS[0]}" > "${done}"
    } &
    local rc=""
    while [ -z "${rc}" ]; do
        sleep 2
        local p; p="$(tail -n1 "${progress}" 2>/dev/null)"; [ -n "${p}" ] && PERCENT=$((30 + p)) && write_status
        local d; d="$(cat "${done}" 2>/dev/null)"; [ "${d}" != "no" ] && rc="${d}"
    done
    [ "${rc}" = "0" ] || fail "rootfs copy (rsync) failed with code ${rc}"
    PERCENT=80; write_status
}

# ---- bootloader + fstab: per platform --------------------------------------

bootloader_x86() {  # grub-install in chroot
    phase "bootloader" 90
    local root_uuid esp_uuid
    if [ "${APPLY}" != "1" ]; then
        log "[dry-run] mount ESP, write fstab (root+ESP UUIDs), chroot grub-install --target=x86_64-efi --efi-directory=/boot/efi --bootloader-id=Airwaves, grub-mkconfig"
        return 0
    fi
    root_uuid="$(blkid -s UUID -o value "${ROOT_DEV}")"
    esp_uuid="$(blkid -s UUID -o value "${BOOT_DEV}")"
    [ -n "${root_uuid}" ] || fail "could not read target root UUID"

    mkdir -p "${TMP}/boot/efi"
    mount "${BOOT_DEV}" "${TMP}/boot/efi" || fail "mount ESP failed"

    cat > "${TMP}/etc/fstab" <<EOF
UUID=${root_uuid}  /          ext4  defaults,noatime,errors=remount-ro  0  1
UUID=${esp_uuid}   /boot/efi  vfat  umask=0077                          0  2
EOF

    for d in dev dev/pts proc sys run; do mount --bind "/${d}" "${TMP}/${d}"; done
    chroot "${TMP}" /bin/bash -c "grub-install --target=x86_64-efi --efi-directory=/boot/efi --bootloader-id=Airwaves --removable" >>"${LOG_TMP}" 2>&1 \
        || { sync; chroot "${TMP}" /bin/bash -c "grub-install --target=x86_64-efi --efi-directory=/boot/efi --bootloader-id=Airwaves" >>"${LOG_TMP}" 2>&1; } \
        || fail "grub-install failed"
    chroot "${TMP}" /bin/bash -c "update-grub || grub-mkconfig -o /boot/grub/grub.cfg" >>"${LOG_TMP}" 2>&1 || fail "grub-mkconfig failed"

    phase "finalizing" 95
    sync
    for d in run sys proc dev/pts dev; do umount -l "${TMP}/${d}" 2>/dev/null; done
    umount -l "${TMP}/boot/efi" 2>/dev/null
    umount -l "${TMP}" 2>/dev/null
    REBOOT_REQUIRED="true"
}

bootloader_uboot() {  # raw-sector u-boot via write_uboot_platform + armbianEnv
    phase "bootloader" 90
    local root_uuid
    if [ "${APPLY}" != "1" ]; then
        log "[dry-run] write fstab (root UUID), set rootdev=UUID in /boot/armbianEnv.txt, write_uboot_platform \$DIR ${TARGET}"
        return 0
    fi
    root_uuid="$(blkid -s UUID -o value "${ROOT_DEV}")"
    [ -n "${root_uuid}" ] || fail "could not read target root UUID"

    cat > "${TMP}/etc/fstab" <<EOF
UUID=${root_uuid}  /  ext4  defaults,noatime,errors=remount-ro  0  1
EOF

    # Point u-boot's boot script at the new root. armbianEnv.txt lives on the
    # target's root partition (single-partition Armbian rockchip layout); the
    # boot.scr reads it at boot, so updating it is sufficient.
    local env="${TMP}/boot/armbianEnv.txt"
    if [ -f "${env}" ]; then
        sed -i -e "s,^rootdev=.*,rootdev=UUID=${root_uuid}," -e "s,^rootfstype=.*,rootfstype=ext4," "${env}"
        grep -q '^rootdev=' "${env}"     || echo "rootdev=UUID=${root_uuid}" >> "${env}"
        grep -q '^rootfstype=' "${env}"  || echo "rootfstype=ext4" >> "${env}"
    else
        mkdir -p "${TMP}/boot"
        printf 'rootdev=UUID=%s\nrootfstype=ext4\n' "${root_uuid}" > "${env}"
    fi

    # Write the board's u-boot to the target's raw sectors using Armbian's
    # on-device, board-correct function (handles all rk3588 blob variants).
    # shellcheck disable=SC1091
    . /usr/lib/u-boot/platform_install.sh
    type write_uboot_platform >/dev/null 2>&1 || fail "write_uboot_platform not available after sourcing platform_install.sh"
    [ -n "${DIR:-}" ] && [ -d "${DIR}" ] || fail "u-boot blob dir (\$DIR=${DIR:-unset}) not found"
    log "Writing u-boot from ${DIR} to ${TARGET}"
    write_uboot_platform "${DIR}" "${TARGET}" >>"${LOG_TMP}" 2>&1 || fail "write_uboot_platform failed: $(tail -n3 "${LOG_TMP}" 2>/dev/null)"

    phase "finalizing" 95
    sync
    umount -l "${TMP}" 2>/dev/null
    REBOOT_REQUIRED="true"
}

bootloader_rpi() {  # stage FAT firmware partition + point cmdline/fstab at new root
    phase "bootloader" 90
    local root_uuid boot_uuid
    if [ "${APPLY}" != "1" ]; then
        log "[dry-run] mount firmware FAT, rsync /boot/firmware, write fstab, set root=UUID in cmdline.txt"
        return 0
    fi
    root_uuid="$(blkid -s UUID -o value "${ROOT_DEV}")"
    [ -n "${root_uuid}" ] || fail "could not read target root UUID"

    mkdir -p "${TMP}/boot/firmware"
    mount "${BOOT_DEV}" "${TMP}/boot/firmware" || fail "mount firmware partition failed"
    boot_uuid="$(blkid -s UUID -o value "${BOOT_DEV}")"

    # Stage the GPU firmware + kernel + dtbs from the running system's FAT
    # partition (a separate mount, so the rootfs rsync did not include it).
    if mountpoint -q /boot/firmware; then
        rsync -a /boot/firmware/ "${TMP}/boot/firmware/" >>"${LOG_TMP}" 2>&1 || fail "copy of /boot/firmware failed"
    else
        fail "/boot/firmware is not mounted; cannot stage Pi boot files"
    fi

    cat > "${TMP}/etc/fstab" <<EOF
UUID=${root_uuid}  /               ext4  defaults,noatime,errors=remount-ro  0  1
UUID=${boot_uuid}  /boot/firmware  vfat  defaults                            0  2
EOF

    # cmdline.txt ships root=LABEL=armbi_root; the source root carries the same
    # label, so target by UUID instead to avoid an ambiguous LABEL= match.
    local cmd="${TMP}/boot/firmware/cmdline.txt"
    if [ -f "${cmd}" ]; then
        sed -i -E "s#root=[^ ]+#root=UUID=${root_uuid}#" "${cmd}"
        grep -q "root=UUID=${root_uuid}" "${cmd}" || fail "failed to set root= in cmdline.txt"
    else
        fail "cmdline.txt missing on firmware partition; cannot set boot root"
    fi

    phase "finalizing" 95
    sync
    umount -l "${TMP}/boot/firmware" 2>/dev/null
    umount -l "${TMP}" 2>/dev/null
    REBOOT_REQUIRED="true"
}

# ---- main ------------------------------------------------------------------

case "${1:-}" in
    --list-json) list_targets_json; exit 0 ;;
    --target)    TARGET="${2:-}" ;;
    "")          fail "usage: airwaves-install --target <disk> | --list-json" ;;
    *)           TARGET="${1}" ;;
esac

write_status
preflight
case "${PLATFORM}" in
    uefi-x86) partition_x86;   copy_rootfs; bootloader_x86 ;;
    uboot)    partition_uboot; copy_rootfs; bootloader_uboot ;;
    rpi)      partition_rpi;   copy_rootfs; bootloader_rpi ;;
    *)        fail "Unsupported platform: ${PLATFORM}" ;;
esac

STATE="success"
PHASE="done"
PERCENT=100
log "Install complete. Reboot and remove the boot drive to boot from ${TARGET}."
write_status "$(date -u +%Y-%m-%dT%H:%M:%SZ)"
