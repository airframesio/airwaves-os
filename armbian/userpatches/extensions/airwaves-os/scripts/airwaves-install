#!/bin/bash
#
# airwaves-install — install the running (live USB / SD) Airwaves OS system onto
# an internal disk (NVMe / eMMC / SATA / USB-SSD). Reuses Armbian's proven
# per-platform disk approach but replaces the interactive dialog UI with a
# structured status.json (same shape as airwaves-update) so the console wizard,
# web UI, and any other front-end can render branded, structured progress.
#
# Supported platforms (auto-detected):
#   - uefi-x86   : GPT + FAT32 ESP + ext4 root, grub-install in a chroot.
#   - uboot      : Rockchip rk3588 (Rock 5B, Orange Pi 5) and other u-boot ARM
#                  boards. ext4 root starting at 16MiB; the bootloader is written
#                  to raw sectors via Armbian's on-device write_uboot_platform.
#   - rpi        : Raspberry Pi (bcm2711). FAT32 /boot/firmware + ext4 root; the
#                  GPU firmware boots the kernel directly (no grub/u-boot).
#
# SAFETY: destructive disk operations only run when AIRWAVES_INSTALL_APPLY=1.
# Without it, the script performs all preflight checks and prints the plan
# (dry-run). Front-ends pass APPLY=1 only after explicit user confirmation.
#
# Usage:
#   airwaves-install --list-json                 # list candidate target disks (JSON)
#   airwaves-install --target /dev/nvme0n1       # dry-run plan for that disk
#   AIRWAVES_INSTALL_APPLY=1 airwaves-install --target /dev/nvme0n1   # real install
#
set -uo pipefail

STATUS_DIR="/etc/airwaves/install"
STATUS="${STATUS_DIR}/status.json"
LOG_TMP="$(mktemp /tmp/airwaves-install.log.XXXXXX)"
STATUS_LOG_LINES=200

STATE="running"
PHASE="preflight"
PERCENT=0
ERROR=""
REBOOT_REQUIRED="false"
STARTED_AT="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
TARGET=""
APPLY="${AIRWAVES_INSTALL_APPLY:-0}"

# Set by detect_platform / the partition step.
PLATFORM=""
ARCH=""
BOARD=""
BOARDFAMILY=""
ROOT_DEV=""    # target root partition device
BOOT_DEV=""    # target ESP/firmware partition device (empty for uboot)
AWCFG_DEV=""   # target AWCFG (FAT32 config) partition device — last partition
TMP=""

# Size reserved at the end of the disk for the AWCFG config partition (FAT32).
# Kept well above the FAT32 minimum so mkfs.vfat -F32 never balks.
AWCFG_END_RESERVE_MIB=100
# Optional path to a provisioning config (hostname/wifi/channel/...) to seed onto
# the target's AWCFG partition. Set via --config; written by airwaves-preconfig /
# airwaves-firstrun. Destructive flags are always forced off on the target.
INSTALL_CONFIG=""

mkdir -p "${STATUS_DIR}"

log() {
    local line
    line="[$(date -u +%H:%M:%S)] $*"
    echo "${line}" >&2
    echo "${line}" >> "${LOG_TMP}"
}

write_status() {
    local finished="${1:-}"
    local finished_field="null"
    [ -n "${finished}" ] && finished_field="\"${finished}\""
    local err_field="null"
    [ -n "${ERROR}" ] && err_field="$(jq -Rn --arg e "${ERROR}" '$e')"
    jq -Rn \
        --arg state "${STATE}" \
        --arg phase "${PHASE}" \
        --argjson percent "${PERCENT}" \
        --argjson reboot "${REBOOT_REQUIRED}" \
        --arg started "${STARTED_AT}" \
        --arg target "${TARGET}" \
        --slurpfile loglines <(tail -n "${STATUS_LOG_LINES}" "${LOG_TMP}" 2>/dev/null | jq -R .) \
        "{
            state: \$state,
            phase: \$phase,
            percent: \$percent,
            target: \$target,
            reboot_required: \$reboot,
            error: ${err_field},
            started_at: \$started,
            finished_at: ${finished_field},
            log: \$loglines
        }" > "${STATUS}.tmp" 2>/dev/null && mv "${STATUS}.tmp" "${STATUS}"
}

phase() {
    PHASE="$1"
    PERCENT="${2:-$PERCENT}"
    log "==> ${PHASE} (${PERCENT}%)"
    write_status
}

fail() {
    STATE="failed"
    ERROR="$1"
    log "ERROR: ${ERROR}"
    write_status "$(date -u +%Y-%m-%dT%H:%M:%SZ)"
    exit 1
}

# ---- platform detection ----------------------------------------------------

detect_platform() {
    ARCH="$(uname -m)"
    if [ -r /etc/armbian-release ]; then
        BOARD="$(awk -F= '/^BOARD=/{gsub(/"/,"",$2);print $2}' /etc/armbian-release 2>/dev/null)"
        BOARDFAMILY="$(awk -F= '/^BOARDFAMILY=/{gsub(/"/,"",$2);print $2}' /etc/armbian-release 2>/dev/null)"
    fi

    # x86 + UEFI: the live-USB installer target.
    if [ "${ARCH}" = "x86_64" ] && [ -d /sys/firmware/efi ]; then
        PLATFORM="uefi-x86"; return 0
    fi
    # Raspberry Pi: GPU firmware boots from a FAT partition (no u-boot/grub).
    case "${BOARDFAMILY}" in bcm27*|bcm28*) PLATFORM="rpi"; return 0 ;; esac
    case "${BOARD}" in rpi*|raspberrypi*) PLATFORM="rpi"; return 0 ;; esac
    # Rockchip and other u-boot boards: bootloader lives in raw sectors and is
    # written by the on-device write_uboot_platform (from the u-boot package).
    if [ -f /usr/lib/u-boot/platform_install.sh ]; then PLATFORM="uboot"; return 0; fi
    case "${BOARDFAMILY}" in rockchip*|sunxi*|meson*|rk*) PLATFORM="uboot"; return 0 ;; esac

    PLATFORM="unknown"
}

# ---- source / target discovery (mirrors armbian-install) -------------------

discover_source() {
    ROOT_UUID="$(sed -e 's/^.*root=//' -e 's/ .*$//' < /proc/cmdline)"
    ROOT_PART="$(blkid | tr -d '":' | grep -w "${ROOT_UUID#UUID=}" | awk '{print $1}' | head -1)"
    [ -z "${ROOT_PART}" ] && ROOT_PART="$(findmnt -no SOURCE / 2>/dev/null)"
    SOURCE_DISK_NAME="$(lsblk -ndo pkname "${ROOT_PART}" 2>/dev/null)"
    # If we cannot resolve the parent disk, SOURCE_DISK would collapse to "/dev/"
    # and the source/boot disk would NOT be excluded from candidate targets (it
    # could then be offered as — or auto-resolved to — an install target and
    # erased). Refuse instead. --list-json then returns nothing (fail-safe).
    [ -n "${SOURCE_DISK_NAME}" ] || fail "cannot determine the source/boot disk (no parent for ${ROOT_PART:-?}); refusing to proceed"
    SOURCE_DISK="/dev/${SOURCE_DISK_NAME}"
}

# Candidate internal target disks: real disks, not the source (boot) device, not
# optical/virtual. Removable disks are skipped EXCEPT that the source is always
# skipped regardless. One JSON object per disk.
list_targets_json() {
    discover_source
    local rows="[]"
    # MODEL is read LAST because it is frequently empty (virtio, some NVMe); a
    # blank middle column would shift positional fields and drop the disk.
    while read -r name rm type size model; do
        [ "${type}" != "disk" ] && continue
        [ "${rm}" = "1" ] && continue                 # skip removable (the USB/SD)
        [ "/dev/${name}" = "${SOURCE_DISK}" ] && continue
        # Skip optical, virtual, and pseudo block devices (never install targets).
        case "${name}" in sr*|loop*|ram*|zram*|fd*|dm-*|md*|nbd*) continue;; esac
        rows="$(jq -c \
            --arg dev "/dev/${name}" \
            --arg size "${size}" \
            --arg model "${model}" \
            '. + [{device:$dev, size:$size, model:($model|gsub("^ +| +$";""))}]' \
            <<<"${rows}")"
    done < <(lsblk -dno NAME,RM,TYPE,SIZE,MODEL)
    echo "${rows}"
}

# Inspect one whole disk: read-only mount each partition to detect an existing
# Airwaves OS install (via /etc/airwaves-release) or another OS (/etc/os-release),
# and summarize the contents. Sets globals consumed by scan_targets_json:
#   AW_PRESENT (true/false), AW_VER, AW_CODE, AW_LAYOUT, DISK_SUMMARY
# Best-effort and always cleans up its mounts; needs root for the mounts.
detect_disk_os() {
    local disk="$1"
    AW_PRESENT="false"; AW_VER=""; AW_CODE=""; AW_LAYOUT=""; DISK_SUMMARY=""
    local os_name="" fstypes="" had_fs=0
    local mp; mp="$(mktemp -d /tmp/aw-scan.XXXXXX 2>/dev/null)" || mp=""
    local p fstype label existing inspect
    # Partitions of this disk (raw NAME output; first line is the disk itself).
    while IFS= read -r p; do
        [ -n "$p" ] || continue
        fstype="$(lsblk -nro FSTYPE "/dev/$p" 2>/dev/null | head -1)"
        label="$(blkid -s LABEL -o value "/dev/$p" 2>/dev/null)"
        [ -n "$fstype" ] && { had_fs=1; case " $fstypes " in *" $fstype "*) :;; *) fstypes="${fstypes:+$fstypes,}$fstype";; esac; }
        case "$label" in
            aw-root-a|aw-root-b) AW_LAYOUT="A/B" ;;
            airwaves-root|armbi_root) [ -z "$AW_LAYOUT" ] && AW_LAYOUT="single" ;;
        esac
        # Only Linux roots can carry the release files; mount those read-only.
        case "$fstype" in
            ext4|ext3|ext2|btrfs) ;;
            *) continue ;;
        esac
        [ -n "$mp" ] || continue
        inspect=""; existing="$(findmnt -nro TARGET -S "/dev/$p" 2>/dev/null | head -1)"
        if [ -n "$existing" ]; then
            inspect="$existing"
        elif timeout 10 mount -o ro,noload "/dev/$p" "$mp" 2>/dev/null \
            || timeout 10 mount -o ro "/dev/$p" "$mp" 2>/dev/null; then
            inspect="$mp"
        fi
        [ -n "$inspect" ] || continue
        if [ -f "${inspect}/etc/airwaves-release" ]; then
            AW_PRESENT="true"
            AW_VER="$(awk -F= '/^AIRWAVES_VERSION=/{gsub(/"/,"",$2);print $2}' "${inspect}/etc/airwaves-release" 2>/dev/null)"
            AW_CODE="$(awk -F= '/^AIRWAVES_CODENAME=/{gsub(/"/,"",$2);print $2}' "${inspect}/etc/airwaves-release" 2>/dev/null)"
        elif [ -z "$os_name" ] && [ -f "${inspect}/etc/os-release" ]; then
            os_name="$(awk -F= '/^PRETTY_NAME=/{gsub(/"/,"",$2);print $2}' "${inspect}/etc/os-release" 2>/dev/null)"
        fi
        [ "$inspect" = "$mp" ] && { umount "$mp" 2>/dev/null || umount -l "$mp" 2>/dev/null || true; }
        [ "$AW_PRESENT" = "true" ] && break
    done < <(lsblk -rno NAME "$disk" 2>/dev/null | tail -n +2)
    [ -n "$mp" ] && rmdir "$mp" 2>/dev/null || true

    if [ "$AW_PRESENT" = "true" ]; then
        DISK_SUMMARY="Airwaves OS v${AW_VER:-?}${AW_LAYOUT:+ ${AW_LAYOUT}}"
    elif [ -n "$os_name" ]; then
        DISK_SUMMARY="$os_name"
    elif [ "$had_fs" = "1" ]; then
        DISK_SUMMARY="existing data (${fstypes})"
    else
        DISK_SUMMARY="empty / unpartitioned"
    fi
}

# Like list_targets_json but enriched: partition-table type + a contents summary,
# and whether each disk already holds an Airwaves OS install (with version),
# confirmed by mounting. Used by the installer UI to inform the disk choice.
# Heavier than --list-json (it mounts), so it is a separate verb.
scan_targets_json() {
    discover_source
    local rows="[]"
    local name rm type size model disk table
    while read -r name rm type size model; do
        [ "${type}" != "disk" ] && continue
        [ "${rm}" = "1" ] && continue
        [ "/dev/${name}" = "${SOURCE_DISK}" ] && continue
        case "${name}" in sr*|loop*|ram*|zram*|fd*|dm-*|md*|nbd*) continue;; esac
        disk="/dev/${name}"
        table="$(lsblk -ndo PTTYPE "$disk" 2>/dev/null)"
        [ -n "$table" ] || table="$(blkid -p -s PTTYPE -o value "$disk" 2>/dev/null)"
        detect_disk_os "$disk"
        rows="$(jq -c \
            --arg dev "$disk" --arg size "${size}" --arg model "${model}" \
            --arg table "${table:-unknown}" \
            --argjson awpresent "${AW_PRESENT:-false}" \
            --arg awver "${AW_VER:-}" --arg awcode "${AW_CODE:-}" --arg awlayout "${AW_LAYOUT:-}" \
            --arg summary "${DISK_SUMMARY:-}" \
            '. + [{device:$dev, size:$size, model:($model|gsub("^ +| +$";"")), table:$table,
                   airwaves:{present:$awpresent, version:$awver, codename:$awcode, layout:$awlayout},
                   summary:$summary}]' \
            <<<"${rows}")"
    done < <(lsblk -dno NAME,RM,TYPE,SIZE,MODEL)
    echo "${rows}"
}

# ---- preflight guards ------------------------------------------------------

preflight() {
    phase "preflight" 5
    command -v jq >/dev/null     || fail "jq is required"
    command -v parted >/dev/null || fail "parted is required"
    command -v rsync >/dev/null  || fail "rsync is required"
    command -v mkfs.ext4 >/dev/null || fail "mkfs.ext4 not found (e2fsprogs missing from image)"

    detect_platform
    log "Platform: ${PLATFORM} (arch=${ARCH} board=${BOARD:-?} family=${BOARDFAMILY:-?})"
    case "${PLATFORM}" in
        uefi-x86)
            command -v mkfs.vfat >/dev/null || fail "mkfs.vfat not found (dosfstools missing from image)"
            ;;
        rpi)
            command -v mkfs.vfat >/dev/null || fail "mkfs.vfat not found (dosfstools missing from image)"
            mountpoint -q /boot/firmware || [ -d /boot/firmware ] \
                || fail "/boot/firmware not present; cannot stage Raspberry Pi boot files"
            ;;
        uboot)
            [ -f /usr/lib/u-boot/platform_install.sh ] \
                || fail "u-boot platform script (/usr/lib/u-boot/platform_install.sh) missing; cannot install bootloader"
            ;;
        *)
            fail "Unsupported platform for install (arch=${ARCH}, family=${BOARDFAMILY:-unknown}). Supported: x86 UEFI, Rockchip/u-boot ARM, Raspberry Pi."
            ;;
    esac

    [ -n "${TARGET}" ] || fail "No target disk specified"
    [ -b "${TARGET}" ] || fail "Target ${TARGET} is not a block device"

    discover_source
    [ "${TARGET}" = "${SOURCE_DISK}" ] && fail "Refusing to install onto the source/boot device ${TARGET}"

    # Target must be a whole disk, not a partition.
    local ttype
    ttype="$(lsblk -ndo TYPE "${TARGET}")"
    [ "${ttype}" = "disk" ] || fail "Target ${TARGET} is not a whole disk (type=${ttype})"

    # Target must not have mounted partitions.
    if lsblk -nro MOUNTPOINT "${TARGET}" | grep -q .; then
        fail "Target ${TARGET} has mounted partitions; refusing to proceed"
    fi

    log "Source (live) disk: ${SOURCE_DISK}"
    log "Target disk:        ${TARGET}"
    if [ "${APPLY}" != "1" ]; then
        log "DRY-RUN: set AIRWAVES_INSTALL_APPLY=1 to perform the install."
    fi
}

# partition suffix: nvme0n1 -> p1, mmcblk0 -> p1, sda -> 1
part() { case "$1" in *[0-9]) echo "$1p$2";; *) echo "$1$2";; esac; }

# Wait for the kernel + udev to create the given partition device nodes after
# (re)partitioning. parted + udev can lag; mkfs against a missing node fails.
settle_parts() {
    partprobe "${TARGET}" >>"${LOG_TMP}" 2>&1 || true
    command -v udevadm >/dev/null && udevadm settle --timeout=10 >>"${LOG_TMP}" 2>&1 || true
    local n d ok
    for n in $(seq 1 15); do
        ok=1
        for d in "$@"; do [ -b "${d}" ] || ok=0; done
        [ "${ok}" = "1" ] && return 0
        sleep 1
        partprobe "${TARGET}" >>"${LOG_TMP}" 2>&1 || true
    done
    for d in "$@"; do
        [ -b "${d}" ] || fail "partition ${d} never appeared: $(tail -n3 "${LOG_TMP}" 2>/dev/null)"
    done
}

# ---- partition + format: per platform --------------------------------------

partition_x86() {  # GPT + FAT32 ESP(512MiB) + ext4 root + FAT32 AWCFG(tail)
    phase "partitioning" 15
    BOOT_DEV="$(part "${TARGET}" 1)"; ROOT_DEV="$(part "${TARGET}" 2)"; AWCFG_DEV="$(part "${TARGET}" 3)"
    if [ "${APPLY}" != "1" ]; then
        log "[dry-run] wipefs ${TARGET}; gpt; ESP(${BOOT_DEV},fat32,512MiB); root(${ROOT_DEV},ext4,rest-${AWCFG_END_RESERVE_MIB}MiB); AWCFG(${AWCFG_DEV},fat32,${AWCFG_END_RESERVE_MIB}MiB tail)"
        return 0
    fi
    wipefs -a "${TARGET}" >>"${LOG_TMP}" 2>&1
    parted -s "${TARGET}" -- mklabel gpt >>"${LOG_TMP}" 2>&1 || fail "parted mklabel failed"
    parted -s "${TARGET}" -- mkpart "ESP" fat32 1MiB 513MiB >>"${LOG_TMP}" 2>&1 || fail "parted ESP failed"
    parted -s "${TARGET}" -- set 1 esp on >>"${LOG_TMP}" 2>&1
    parted -s "${TARGET}" -- mkpart "airwaves-root" ext4 513MiB "-${AWCFG_END_RESERVE_MIB}MiB" >>"${LOG_TMP}" 2>&1 || fail "parted root failed"
    parted -s "${TARGET}" -- mkpart "AWCFG" fat32 "-${AWCFG_END_RESERVE_MIB}MiB" 100% >>"${LOG_TMP}" 2>&1 || fail "parted AWCFG failed"
    settle_parts "${BOOT_DEV}" "${ROOT_DEV}" "${AWCFG_DEV}"

    phase "formatting" 25
    # FAT volume labels are limited to 11 characters.
    mkfs.vfat -F32 -n AIRWAVES "${BOOT_DEV}" >>"${LOG_TMP}" 2>&1 || fail "mkfs.vfat failed: $(tail -n3 "${LOG_TMP}" 2>/dev/null)"
    mkfs.ext4 -qF -L airwaves-root "${ROOT_DEV}" >>"${LOG_TMP}" 2>&1 || fail "mkfs.ext4 failed: $(tail -n3 "${LOG_TMP}" 2>/dev/null)"
    mkfs.vfat -F32 -n AWCFG "${AWCFG_DEV}" >>"${LOG_TMP}" 2>&1 || fail "mkfs.vfat AWCFG failed: $(tail -n3 "${LOG_TMP}" 2>/dev/null)"
}

partition_uboot() {  # GPT + ext4 root at 16MiB + FAT32 AWCFG(tail); raw u-boot
    phase "partitioning" 15
    BOOT_DEV=""; ROOT_DEV="$(part "${TARGET}" 1)"; AWCFG_DEV="$(part "${TARGET}" 2)"
    if [ "${APPLY}" != "1" ]; then
        log "[dry-run] wipefs ${TARGET}; gpt; root(${ROOT_DEV},ext4,16MiB→rest-${AWCFG_END_RESERVE_MIB}MiB); AWCFG(${AWCFG_DEV},fat32,${AWCFG_END_RESERVE_MIB}MiB tail); u-boot to raw sectors of ${TARGET}"
        return 0
    fi
    wipefs -a "${TARGET}" >>"${LOG_TMP}" 2>&1
    parted -s "${TARGET}" -- mklabel gpt >>"${LOG_TMP}" 2>&1 || fail "parted mklabel failed"
    # Partition 1 starts at 16MiB, matching Armbian's OFFSET, leaving the 0–16MiB
    # region for the raw u-boot blobs written by write_uboot_platform.
    parted -s "${TARGET}" -- mkpart "armbi_root" ext4 16MiB "-${AWCFG_END_RESERVE_MIB}MiB" >>"${LOG_TMP}" 2>&1 || fail "parted root failed"
    parted -s "${TARGET}" -- mkpart "AWCFG" fat32 "-${AWCFG_END_RESERVE_MIB}MiB" 100% >>"${LOG_TMP}" 2>&1 || fail "parted AWCFG failed"
    settle_parts "${ROOT_DEV}" "${AWCFG_DEV}"

    phase "formatting" 25
    mkfs.ext4 -qF -L armbi_root "${ROOT_DEV}" >>"${LOG_TMP}" 2>&1 || fail "mkfs.ext4 failed: $(tail -n3 "${LOG_TMP}" 2>/dev/null)"
    mkfs.vfat -F32 -n AWCFG "${AWCFG_DEV}" >>"${LOG_TMP}" 2>&1 || fail "mkfs.vfat AWCFG failed: $(tail -n3 "${LOG_TMP}" 2>/dev/null)"
}

partition_rpi() {  # GPT + FAT32 /boot/firmware(512MiB) + ext4 root + FAT32 AWCFG(tail)
    phase "partitioning" 15
    BOOT_DEV="$(part "${TARGET}" 1)"; ROOT_DEV="$(part "${TARGET}" 2)"; AWCFG_DEV="$(part "${TARGET}" 3)"
    if [ "${APPLY}" != "1" ]; then
        log "[dry-run] wipefs ${TARGET}; gpt; firmware(${BOOT_DEV},fat32,512MiB,RPICFG); root(${ROOT_DEV},ext4,rest-${AWCFG_END_RESERVE_MIB}MiB); AWCFG(${AWCFG_DEV},fat32,${AWCFG_END_RESERVE_MIB}MiB tail)"
        return 0
    fi
    wipefs -a "${TARGET}" >>"${LOG_TMP}" 2>&1
    parted -s "${TARGET}" -- mklabel gpt >>"${LOG_TMP}" 2>&1 || fail "parted mklabel failed"
    parted -s "${TARGET}" -- mkpart "RPICFG" fat32 1MiB 513MiB >>"${LOG_TMP}" 2>&1 || fail "parted firmware failed"
    # The Raspberry Pi firmware boots a FAT data partition directly; the ESP flag
    # is intentionally NOT set (matches Armbian, which clears it for Pi 3/4).
    parted -s "${TARGET}" -- mkpart "armbi_root" ext4 513MiB "-${AWCFG_END_RESERVE_MIB}MiB" >>"${LOG_TMP}" 2>&1 || fail "parted root failed"
    parted -s "${TARGET}" -- mkpart "AWCFG" fat32 "-${AWCFG_END_RESERVE_MIB}MiB" 100% >>"${LOG_TMP}" 2>&1 || fail "parted AWCFG failed"
    settle_parts "${BOOT_DEV}" "${ROOT_DEV}" "${AWCFG_DEV}"

    phase "formatting" 25
    mkfs.vfat -F32 -n RPICFG "${BOOT_DEV}" >>"${LOG_TMP}" 2>&1 || fail "mkfs.vfat failed: $(tail -n3 "${LOG_TMP}" 2>/dev/null)"
    mkfs.ext4 -qF -L armbi_root "${ROOT_DEV}" >>"${LOG_TMP}" 2>&1 || fail "mkfs.ext4 failed: $(tail -n3 "${LOG_TMP}" 2>/dev/null)"
    mkfs.vfat -F32 -n AWCFG "${AWCFG_DEV}" >>"${LOG_TMP}" 2>&1 || fail "mkfs.vfat AWCFG failed: $(tail -n3 "${LOG_TMP}" 2>/dev/null)"
}

# ---- copy rootfs (rsync with live progress) --------------------------------
# Shared across platforms: mounts the target root and rsyncs the running rootfs.
# rsync -x stays on one filesystem, so separate mounts (the ESP/firmware on the
# source, pseudo-fs) are not descended into; per-platform boot files are staged
# in the bootloader step.

copy_rootfs() {
    phase "copying-rootfs" 30
    TMP="$(mktemp -d /mnt/airwaves-install.XXXXXX)"

    cat > /tmp/airwaves-install-exclude <<'EOF'
/dev/*
/proc/*
/sys/*
/tmp/*
/run/*
/mnt/*
/media/*
/lost+found
/var/log.hdd/*
/swapfile
/etc/airwaves/install/*
# Don't copy the live Docker/containerd store: it's being written while we
# rsync (docker is running), so the copy is inconsistent and the target's
# content store ends up with dangling layer references ("blob not found").
# The installed system pulls the app images fresh on first boot, same as the
# live USB does.
/var/lib/docker/*
/var/lib/containerd/*
/var/lib/docker.hdd/*
EOF

    if [ "${APPLY}" != "1" ]; then
        log "[dry-run] rsync / -> ${ROOT_DEV} (excludes pseudo-fs); would stream progress 30→80%"
        PERCENT=80; write_status
        rmdir "${TMP}" 2>/dev/null || true
        return 0
    fi

    mount "${ROOT_DEV}" "${TMP}" || fail "mount ${ROOT_DEV} failed"
    echo "${TMP}" >/tmp/airwaves-install-mnt

    local todo
    todo="$(rsync -anx --delete --stats --exclude-from=/tmp/airwaves-install-exclude / "${TMP}" 2>/dev/null | awk '/Number of files:/{gsub(/[.,]/,"",$4); print $4; exit}')"
    [ -z "${todo}" ] && todo=1
    local progress=/tmp/airwaves-install-progress; echo 0 >"${progress}"; local done=/tmp/airwaves-install-done; echo no >"${done}"
    {
        rsync -ax --delete --exclude-from=/tmp/airwaves-install-exclude / "${TMP}" \
            | stdbuf -oL awk -v todo="${todo}" '{p=int(50*NR/todo); if(p>50)p=50; print p; fflush()}' > "${progress}"
        echo "${PIPESTATUS[0]}" > "${done}"
    } &
    local rc=""
    while [ -z "${rc}" ]; do
        sleep 2
        local p; p="$(tail -n1 "${progress}" 2>/dev/null)"; [ -n "${p}" ] && PERCENT=$((30 + p)) && write_status
        local d; d="$(cat "${done}" 2>/dev/null)"; [ "${d}" != "no" ] && rc="${d}"
    done
    [ "${rc}" = "0" ] || fail "rootfs copy (rsync) failed with code ${rc}"
    reset_firstboot_markers "${TMP}"
    phase "seeding-containers" 80
    seed_target_containers "${TMP}"
    PERCENT=80; write_status
}

# Reset first-boot state on the target so it re-initializes (fresh device id,
# hostname, container load) and applies its AWCFG config on first boot. The
# rsync copies the live system's markers (which may be in the post-init state),
# so clear .initialized and arm .needs-first-run.
reset_firstboot_markers() {
    local root="$1"
    mkdir -p "${root}/opt/airwaves" 2>/dev/null || true
    rm -f "${root}/opt/airwaves/.initialized" 2>/dev/null || true
    touch "${root}/opt/airwaves/.needs-first-run" 2>/dev/null || true
}

# Make the installed system bootable OFFLINE: docker-save the manager+gateway
# images this live system is running into the target's /opt/airwaves/images so
# the target's airwaves-init loads them on first boot (no registry pull). The
# image's PRE-BAKED tarballs were already consumed (deleted) when THIS live USB
# first booted, so the rsync copy carries an empty images dir — we recreate them
# from the running docker here. Best-effort: if docker/images are unavailable the
# target falls back to pulling online.
seed_target_containers() {
    local root="$1"
    local imgdir="${root}/opt/airwaves/images"
    local compose="/etc/airwaves/docker-compose.yml"
    command -v docker >/dev/null 2>&1 || { log "docker unavailable; target will pull containers on first boot (needs network)"; return 0; }
    [ -f "${compose}" ] || { log "no compose on live system; skipping container seed"; return 0; }
    local refs
    refs="$(grep -oE 'ghcr\.io/airframesio/airwaves-[a-z]+:[A-Za-z0-9._-]+' "${compose}" 2>/dev/null | sort -u)"
    [ -n "${refs}" ] || { log "no airwaves image refs in compose; skipping container seed"; return 0; }
    mkdir -p "${imgdir}" 2>/dev/null || true
    local ref name ok=0
    while IFS= read -r ref; do
        [ -n "${ref}" ] || continue
        if ! docker image inspect "${ref}" >/dev/null 2>&1; then
            log "image ${ref} not present on live system; target will pull it"
            continue
        fi
        name="$(printf '%s' "${ref}" | sed -E 's#^.*/##; s#[:/]#_#g')"
        log "Seeding target container image: ${ref}"
        if docker save -o "${imgdir}/${name}.tar" "${ref}" >>"${LOG_TMP}" 2>&1; then
            ok=$((ok + 1))
        else
            log "WARNING: docker save failed for ${ref}"
            rm -f "${imgdir}/${name}.tar" 2>/dev/null || true
        fi
    done <<< "${refs}"
    log "Seeded ${ok} container image(s) into target ${imgdir}"
}

# ---- bootloader + fstab: per platform --------------------------------------

bootloader_x86() {  # grub-install in chroot
    phase "bootloader" 90
    local root_uuid esp_uuid
    if [ "${APPLY}" != "1" ]; then
        log "[dry-run] mount ESP, write fstab (root+ESP UUIDs), chroot grub-install --target=x86_64-efi --efi-directory=/boot/efi --bootloader-id=Airwaves, grub-mkconfig"
        return 0
    fi
    root_uuid="$(blkid -s UUID -o value "${ROOT_DEV}")"
    esp_uuid="$(blkid -s UUID -o value "${BOOT_DEV}")"
    [ -n "${root_uuid}" ] || fail "could not read target root UUID"

    mkdir -p "${TMP}/boot/efi"
    mount "${BOOT_DEV}" "${TMP}/boot/efi" || fail "mount ESP failed"

    cat > "${TMP}/etc/fstab" <<EOF
UUID=${root_uuid}  /          ext4  defaults,noatime,errors=remount-ro  0  1
UUID=${esp_uuid}   /boot/efi  vfat  umask=0077                          0  2
EOF

    for d in dev dev/pts proc sys run; do mount --bind "/${d}" "${TMP}/${d}"; done
    chroot "${TMP}" /bin/bash -c "grub-install --target=x86_64-efi --efi-directory=/boot/efi --bootloader-id=Airwaves --removable" >>"${LOG_TMP}" 2>&1 \
        || { sync; chroot "${TMP}" /bin/bash -c "grub-install --target=x86_64-efi --efi-directory=/boot/efi --bootloader-id=Airwaves" >>"${LOG_TMP}" 2>&1; } \
        || fail "grub-install failed"
    chroot "${TMP}" /bin/bash -c "update-grub || grub-mkconfig -o /boot/grub/grub.cfg" >>"${LOG_TMP}" 2>&1 || fail "grub-mkconfig failed"

    phase "finalizing" 95
    sync
    for d in run sys proc dev/pts dev; do umount -l "${TMP}/${d}" 2>/dev/null; done
    umount -l "${TMP}/boot/efi" 2>/dev/null
    umount -l "${TMP}" 2>/dev/null
    REBOOT_REQUIRED="true"
}

bootloader_uboot() {  # raw-sector u-boot via write_uboot_platform + armbianEnv
    phase "bootloader" 90
    local root_uuid
    if [ "${APPLY}" != "1" ]; then
        log "[dry-run] write fstab (root UUID), set rootdev=UUID in /boot/armbianEnv.txt, write_uboot_platform \$DIR ${TARGET}"
        return 0
    fi
    root_uuid="$(blkid -s UUID -o value "${ROOT_DEV}")"
    [ -n "${root_uuid}" ] || fail "could not read target root UUID"

    cat > "${TMP}/etc/fstab" <<EOF
UUID=${root_uuid}  /  ext4  defaults,noatime,errors=remount-ro  0  1
EOF

    # Point u-boot's boot script at the new root. armbianEnv.txt lives on the
    # target's root partition (single-partition Armbian rockchip layout); the
    # boot.scr reads it at boot, so updating it is sufficient.
    local env="${TMP}/boot/armbianEnv.txt"
    if [ -f "${env}" ]; then
        sed -i -e "s,^rootdev=.*,rootdev=UUID=${root_uuid}," -e "s,^rootfstype=.*,rootfstype=ext4," "${env}"
        grep -q '^rootdev=' "${env}"     || echo "rootdev=UUID=${root_uuid}" >> "${env}"
        grep -q '^rootfstype=' "${env}"  || echo "rootfstype=ext4" >> "${env}"
    else
        mkdir -p "${TMP}/boot"
        printf 'rootdev=UUID=%s\nrootfstype=ext4\n' "${root_uuid}" > "${env}"
    fi

    # Write the board's u-boot to the target's raw sectors using Armbian's
    # on-device, board-correct function (handles all rk3588 blob variants).
    # shellcheck disable=SC1091
    . /usr/lib/u-boot/platform_install.sh
    type write_uboot_platform >/dev/null 2>&1 || fail "write_uboot_platform not available after sourcing platform_install.sh"
    [ -n "${DIR:-}" ] && [ -d "${DIR}" ] || fail "u-boot blob dir (\$DIR=${DIR:-unset}) not found"
    log "Writing u-boot from ${DIR} to ${TARGET}"
    write_uboot_platform "${DIR}" "${TARGET}" >>"${LOG_TMP}" 2>&1 || fail "write_uboot_platform failed: $(tail -n3 "${LOG_TMP}" 2>/dev/null)"

    phase "finalizing" 95
    sync
    umount -l "${TMP}" 2>/dev/null
    REBOOT_REQUIRED="true"
}

bootloader_rpi() {  # stage FAT firmware partition + point cmdline/fstab at new root
    phase "bootloader" 90
    local root_uuid boot_uuid
    if [ "${APPLY}" != "1" ]; then
        log "[dry-run] mount firmware FAT, rsync /boot/firmware, write fstab, set root=UUID in cmdline.txt"
        return 0
    fi
    root_uuid="$(blkid -s UUID -o value "${ROOT_DEV}")"
    [ -n "${root_uuid}" ] || fail "could not read target root UUID"

    mkdir -p "${TMP}/boot/firmware"
    mount "${BOOT_DEV}" "${TMP}/boot/firmware" || fail "mount firmware partition failed"
    boot_uuid="$(blkid -s UUID -o value "${BOOT_DEV}")"

    # Stage the GPU firmware + kernel + dtbs from the running system's FAT
    # partition (a separate mount, so the rootfs rsync did not include it).
    if mountpoint -q /boot/firmware; then
        rsync -a /boot/firmware/ "${TMP}/boot/firmware/" >>"${LOG_TMP}" 2>&1 || fail "copy of /boot/firmware failed"
    else
        fail "/boot/firmware is not mounted; cannot stage Pi boot files"
    fi

    cat > "${TMP}/etc/fstab" <<EOF
UUID=${root_uuid}  /               ext4  defaults,noatime,errors=remount-ro  0  1
UUID=${boot_uuid}  /boot/firmware  vfat  defaults                            0  2
EOF

    # cmdline.txt ships root=LABEL=armbi_root; the source root carries the same
    # label, so target by UUID instead to avoid an ambiguous LABEL= match.
    local cmd="${TMP}/boot/firmware/cmdline.txt"
    if [ -f "${cmd}" ]; then
        sed -i -E "s#root=[^ ]+#root=UUID=${root_uuid}#" "${cmd}"
        grep -q "root=UUID=${root_uuid}" "${cmd}" || fail "failed to set root= in cmdline.txt"
    else
        fail "cmdline.txt missing on firmware partition; cannot set boot root"
    fi

    phase "finalizing" 95
    sync
    umount -l "${TMP}/boot/firmware" 2>/dev/null
    umount -l "${TMP}" 2>/dev/null
    REBOOT_REQUIRED="true"
}

# ============================================================================
# A/B (blue/green) install — x86 UEFI (Phase 1). Two equal root slots + a shared
# aw-data partition (holds /etc/airwaves + /var/lib/docker via bind mounts), with
# GRUB + grub.cfg + grubenv on the shared ESP selecting the slot. See
# docs/AB-UPDATES.md. ARM A/B comes in later phases.
# ============================================================================
ESP_DEV=""; ROOTA_DEV=""; ROOTB_DEV=""; DATA_DEV=""; KVER=""

ab_slot_mib() {
    # slot size = clamp(35% of disk, 4 GiB, 12 GiB), in MiB
    local bytes mib slot
    bytes="$(blockdev --getsize64 "${TARGET}" 2>/dev/null || echo 0)"
    mib=$(( bytes / 1024 / 1024 ))
    slot=$(( mib * 35 / 100 ))
    [ "${slot}" -lt 4096 ] && slot=4096
    [ "${slot}" -gt 12288 ] && slot=12288
    echo "${slot}"
}

partition_x86_ab() {
    phase "partitioning" 15
    ESP_DEV="$(part "${TARGET}" 1)"; ROOTA_DEV="$(part "${TARGET}" 2)"
    ROOTB_DEV="$(part "${TARGET}" 3)"; DATA_DEV="$(part "${TARGET}" 4)"; AWCFG_DEV="$(part "${TARGET}" 5)"
    local slot esp_end a_end b_end disk_mib
    slot="$(ab_slot_mib)"
    disk_mib=$(( $(blockdev --getsize64 "${TARGET}" 2>/dev/null || echo 0) / 1024 / 1024 ))
    esp_end=513; a_end=$(( esp_end + slot )); b_end=$(( a_end + slot ))
    # Policy: A/B requires a >=12 GiB disk (below that, callers use single-root).
    if [ "${disk_mib}" -lt 12288 ]; then
        fail "A/B needs a >=12 GiB disk (this disk is ${disk_mib}MiB). Install without --ab for a single-root system."
    fi
    # Reserve room for 2 slots + a >=1GiB data partition + the AWCFG tail.
    if [ "$(( b_end + 1024 + AWCFG_END_RESERVE_MIB ))" -ge "${disk_mib}" ]; then
        fail "Disk too small for A/B (${disk_mib}MiB; need 2x${slot}MiB slots + data + AWCFG). Use a single-root install (omit --ab)."
    fi
    if [ "${APPLY}" != "1" ]; then
        log "[dry-run] gpt: ESP(1-513) rootA(513-${a_end}) rootB(${a_end}-${b_end}) data(${b_end}-rest-${AWCFG_END_RESERVE_MIB}MiB) AWCFG(${AWCFG_END_RESERVE_MIB}MiB tail); slot=${slot}MiB"
        return 0
    fi
    wipefs -a "${TARGET}" >>"${LOG_TMP}" 2>&1
    parted -s "${TARGET}" -- mklabel gpt >>"${LOG_TMP}" 2>&1 || fail "parted mklabel failed"
    parted -s "${TARGET}" -- mkpart "ESP" fat32 1MiB 513MiB >>"${LOG_TMP}" 2>&1 || fail "parted ESP failed"
    parted -s "${TARGET}" -- set 1 esp on >>"${LOG_TMP}" 2>&1
    parted -s "${TARGET}" -- mkpart "aw-root-a" ext4 513MiB "${a_end}MiB" >>"${LOG_TMP}" 2>&1 || fail "parted rootA failed"
    parted -s "${TARGET}" -- mkpart "aw-root-b" ext4 "${a_end}MiB" "${b_end}MiB" >>"${LOG_TMP}" 2>&1 || fail "parted rootB failed"
    parted -s "${TARGET}" -- mkpart "aw-data" ext4 "${b_end}MiB" "-${AWCFG_END_RESERVE_MIB}MiB" >>"${LOG_TMP}" 2>&1 || fail "parted data failed"
    parted -s "${TARGET}" -- mkpart "AWCFG" fat32 "-${AWCFG_END_RESERVE_MIB}MiB" 100% >>"${LOG_TMP}" 2>&1 || fail "parted AWCFG failed"
    settle_parts "${ESP_DEV}" "${ROOTA_DEV}" "${ROOTB_DEV}" "${DATA_DEV}" "${AWCFG_DEV}"

    phase "formatting" 25
    mkfs.vfat -F32 -n AIRWAVES "${ESP_DEV}" >>"${LOG_TMP}" 2>&1 || fail "mkfs.vfat failed: $(tail -n3 "${LOG_TMP}" 2>/dev/null)"
    mkfs.ext4 -qF -L aw-root-a "${ROOTA_DEV}" >>"${LOG_TMP}" 2>&1 || fail "mkfs rootA failed"
    mkfs.ext4 -qF -L aw-root-b "${ROOTB_DEV}" >>"${LOG_TMP}" 2>&1 || fail "mkfs rootB failed"
    mkfs.ext4 -qF -L aw-data   "${DATA_DEV}"  >>"${LOG_TMP}" 2>&1 || fail "mkfs data failed"
    mkfs.vfat -F32 -n AWCFG    "${AWCFG_DEV}" >>"${LOG_TMP}" 2>&1 || fail "mkfs AWCFG failed: $(tail -n3 "${LOG_TMP}" 2>/dev/null)"
}

copy_rootfs_ab() {
    phase "copying-rootfs" 30
    TMP="$(mktemp -d /mnt/airwaves-install.XXXXXX)"
    cat > /tmp/airwaves-install-exclude <<'EOF'
/dev/*
/proc/*
/sys/*
/tmp/*
/run/*
/mnt/*
/media/*
/lost+found
/var/log.hdd/*
/swapfile
/etc/airwaves/install/*
/var/lib/docker/*
/var/lib/containerd/*
/var/lib/docker.hdd/*
EOF
    if [ "${APPLY}" != "1" ]; then
        log "[dry-run] rsync / -> rootA; seed aw-data {airwaves,docker}; snapshot rootA -> rootB"
        PERCENT=80; write_status; rmdir "${TMP}" 2>/dev/null || true; return 0
    fi

    mount "${ROOTA_DEV}" "${TMP}" || fail "mount rootA failed"
    echo "${TMP}" >/tmp/airwaves-install-mnt
    local todo
    todo="$(rsync -anx --delete --stats --exclude-from=/tmp/airwaves-install-exclude / "${TMP}" 2>/dev/null | awk '/Number of files:/{gsub(/[.,]/,"",$4); print $4; exit}')"
    [ -z "${todo}" ] && todo=1
    local progress=/tmp/airwaves-install-progress; echo 0 >"${progress}"; local done=/tmp/airwaves-install-done; echo no >"${done}"
    {
        rsync -ax --delete --exclude-from=/tmp/airwaves-install-exclude / "${TMP}" \
            | stdbuf -oL awk -v todo="${todo}" '{p=int(45*NR/todo); if(p>45)p=45; print p; fflush()}' > "${progress}"
        echo "${PIPESTATUS[0]}" > "${done}"
    } &
    local rc=""
    while [ -z "${rc}" ]; do
        sleep 2
        local p; p="$(tail -n1 "${progress}" 2>/dev/null)"; [ -n "${p}" ] && PERCENT=$((30 + p)) && write_status
        local d; d="$(cat "${done}" 2>/dev/null)"; [ "${d}" != "no" ] && rc="${d}"
    done
    [ "${rc}" = "0" ] || fail "rootfs copy (rsync) failed with code ${rc}"
    # Clear/arm first-boot markers BEFORE cloning rootA -> rootB so both slots
    # come up fresh and apply their AWCFG config on first boot.
    reset_firstboot_markers "${TMP}"
    # Seed offline container images into rootA before the clone so BOTH slots
    # carry them.
    seed_target_containers "${TMP}"

    # Seed shared data: /data/{airwaves,docker}; relocate copied /etc/airwaves
    # into /data/airwaves (bind-mounted back via fstab).
    phase "seeding-data" 78
    local DATAMNT; DATAMNT="$(mktemp -d /mnt/airwaves-data.XXXXXX)"
    mount "${DATA_DEV}" "${DATAMNT}" || fail "mount data failed"
    mkdir -p "${DATAMNT}/airwaves" "${DATAMNT}/docker"
    if [ -d "${TMP}/etc/airwaves" ]; then
        rsync -aHAX "${TMP}/etc/airwaves/" "${DATAMNT}/airwaves/" >>"${LOG_TMP}" 2>&1 \
            || fail "failed to seed /data/airwaves from rootfs copy"
        rm -rf "${TMP}/etc/airwaves"/* 2>/dev/null || true
    fi
    mkdir -p "${TMP}/data" "${TMP}/etc/airwaves" "${TMP}/var/lib/docker"
    umount "${DATAMNT}" 2>/dev/null || true; rmdir "${DATAMNT}" 2>/dev/null || true

    # Snapshot rootA -> rootB (both independently bootable). -x stays on rootA's fs.
    phase "cloning-slot-b" 82
    local RBMNT; RBMNT="$(mktemp -d /mnt/airwaves-rootb.XXXXXX)"
    mount "${ROOTB_DEV}" "${RBMNT}" || fail "mount rootB failed"
    rsync -aHAX -x "${TMP}/" "${RBMNT}/" >>"${LOG_TMP}" 2>&1 || fail "slot B clone failed"
    umount "${RBMNT}" 2>/dev/null || true; rmdir "${RBMNT}" 2>/dev/null || true
    PERCENT=85; write_status
}

# Per-slot /etc/fstab: $1=mountdir $2=this-slot-root-uuid $3=esp-uuid $4=data-uuid
write_ab_fstab() {
    cat > "${1}/etc/fstab" <<EOF
UUID=${2}  /               ext4  defaults,noatime,errors=remount-ro  0  1
UUID=${3}  /boot/efi       vfat  umask=0077                          0  2
UUID=${4}  /data           ext4  defaults                            0  2
/data/airwaves /etc/airwaves   none  bind                            0  0
/data/docker   /var/lib/docker none  bind                            0  0
EOF
}

bootloader_x86_ab() {
    phase "bootloader" 90
    if [ "${APPLY}" != "1" ]; then
        log "[dry-run] per-slot fstab (A+B); grub-install to ESP; A/B grub.cfg + grubenv (saved_entry=aw-root-a)"
        return 0
    fi
    local ra rb eu du
    ra="$(blkid -s UUID -o value "${ROOTA_DEV}")"; rb="$(blkid -s UUID -o value "${ROOTB_DEV}")"
    eu="$(blkid -s UUID -o value "${ESP_DEV}")";   du="$(blkid -s UUID -o value "${DATA_DEV}")"
    [ -n "${ra}" ] && [ -n "${rb}" ] && [ -n "${eu}" ] && [ -n "${du}" ] || fail "could not read A/B partition UUIDs"
    KVER="$(ls "${TMP}/boot"/vmlinuz-* 2>/dev/null | sed 's|.*/vmlinuz-||' | head -1)"
    [ -n "${KVER}" ] || fail "no kernel found in slot A /boot"
    local osver
    osver="$(awk -F= '/^AIRWAVES_VERSION=/{print $2}' "${TMP}/etc/airwaves-release" 2>/dev/null)"
    osver="${osver:-?}"

    write_ab_fstab "${TMP}" "${ra}" "${eu}" "${du}"
    local RBMNT; RBMNT="$(mktemp -d /mnt/airwaves-rootb.XXXXXX)"
    mount "${ROOTB_DEV}" "${RBMNT}" || fail "remount rootB failed"
    mkdir -p "${RBMNT}/etc" "${RBMNT}/boot/efi" "${RBMNT}/data"
    write_ab_fstab "${RBMNT}" "${rb}" "${eu}" "${du}"
    umount "${RBMNT}" 2>/dev/null || true; rmdir "${RBMNT}" 2>/dev/null || true

    mkdir -p "${TMP}/boot/efi"
    mount "${ESP_DEV}" "${TMP}/boot/efi" || fail "mount ESP failed"
    for d in dev dev/pts proc sys run; do mount --bind "/${d}" "${TMP}/${d}"; done
    chroot "${TMP}" /bin/bash -c "grub-install --target=x86_64-efi --efi-directory=/boot/efi --boot-directory=/boot/efi --bootloader-id=Airwaves --removable" >>"${LOG_TMP}" 2>&1 \
        || { sync; chroot "${TMP}" /bin/bash -c "grub-install --target=x86_64-efi --efi-directory=/boot/efi --boot-directory=/boot/efi --bootloader-id=Airwaves" >>"${LOG_TMP}" 2>&1; } \
        || fail "grub-install failed: $(tail -n3 "${LOG_TMP}" 2>/dev/null)"

    cat > "${TMP}/boot/efi/grub/grub.cfg" <<EOF
# Airwaves OS A/B boot config (generated by airwaves-install)
insmod part_gpt
insmod ext2
insmod fat
insmod search_label
if [ -s \$prefix/grubenv ]; then load_env; fi
set default="\${saved_entry}"
if [ -z "\${default}" ]; then set default="aw-root-a"; fi
if [ -n "\${next_entry}" ]; then
    set default="\${next_entry}"
    set next_entry=
    save_env next_entry
fi
set timeout=5
menuentry "Airwaves OS v${osver} (slot A)" --id aw-root-a {
    search --no-floppy --label aw-root-a --set=root
    linux /boot/vmlinuz-${KVER} root=UUID=${ra} rootflags=noatime rw console=tty0 console=ttyS0,115200
    initrd /boot/initrd.img-${KVER}
}
menuentry "Airwaves OS v${osver} (slot B)" --id aw-root-b {
    search --no-floppy --label aw-root-b --set=root
    linux /boot/vmlinuz-${KVER} root=UUID=${rb} rootflags=noatime rw console=tty0 console=ttyS0,115200
    initrd /boot/initrd.img-${KVER}
}
EOF
    grub-editenv "${TMP}/boot/efi/grub/grubenv" create 2>/dev/null || true
    grub-editenv "${TMP}/boot/efi/grub/grubenv" set saved_entry=aw-root-a

    phase "finalizing" 95
    sync
    for d in run sys proc dev/pts dev; do umount -l "${TMP}/${d}" 2>/dev/null; done
    umount -l "${TMP}/boot/efi" 2>/dev/null
    umount -l "${TMP}" 2>/dev/null
    REBOOT_REQUIRED="true"
}

# ---- AWCFG payload on the target -------------------------------------------
# Produce the airwaves-install.json to place on the TARGET's AWCFG partition:
# carry provisioning fields (hostname/wifi/channel/timezone/ssh) from the install
# config when present, but FORCE every destructive flag OFF so the installed
# system never auto-installs. Falls back to the shipped safe-default template.
build_target_awcfg_config() {
    local base="/opt/airwaves/config/awcfg/airwaves-install.json"
    local j="{}"
    [ -f "${base}" ] && j="$(cat "${base}" 2>/dev/null || echo '{}')"
    # Guard a present-but-empty/corrupt template so the merge can't emit "".
    jq -e . <<<"${j}" >/dev/null 2>&1 || j="{}"
    if [ -n "${INSTALL_CONFIG}" ] && [ -f "${INSTALL_CONFIG}" ] && jq -e . "${INSTALL_CONFIG}" >/dev/null 2>&1; then
        j="$(jq -n --argjson b "${j}" --slurpfile s "${INSTALL_CONFIG}" '
            $b * {
              hostname:  ($s[0].hostname  // ""),
              wifi:     {ssid: ($s[0].wifi.ssid // ""), psk: ($s[0].wifi.psk // "")},
              channel:   ($s[0].channel   // ""),
              timezone:  ($s[0].timezone  // ""),
              ssh_keys:  ($s[0].ssh_keys  // [])
            }' 2>/dev/null || printf '%s' "${j}")"
    fi
    printf '%s' "${j}" | jq '.auto_install=false | .confirm_destructive=false | .self_install=false' 2>/dev/null \
        || printf '%s' "${j}"
}

apply_awcfg_payload() {
    [ -n "${AWCFG_DEV}" ] || return 0
    if [ "${APPLY}" != "1" ]; then
        log "[dry-run] write AWCFG config + README to ${AWCFG_DEV}"
        return 0
    fi
    phase "config-partition" 97
    local mp; mp="$(mktemp -d /mnt/airwaves-awcfg.XXXXXX)"
    if ! mount "${AWCFG_DEV}" "${mp}" 2>>"${LOG_TMP}"; then
        log "WARNING: could not mount AWCFG ${AWCFG_DEV}; skipping config payload"
        rmdir "${mp}" 2>/dev/null || true
        return 0
    fi
    local payload; payload="$(build_target_awcfg_config 2>>"${LOG_TMP}")"
    if ! jq -e . <<<"${payload}" >/dev/null 2>&1; then
        log "WARNING: built AWCFG config was invalid; writing safe default"
        payload='{"auto_install":false,"confirm_destructive":false,"self_install":false}'
    fi
    printf '%s\n' "${payload}" > "${mp}/airwaves-install.json"
    [ -f /opt/airwaves/config/awcfg/README.txt ] && cp /opt/airwaves/config/awcfg/README.txt "${mp}/README.txt" 2>/dev/null || true
    sync
    umount "${mp}" 2>/dev/null || umount -l "${mp}" 2>/dev/null || true
    rmdir "${mp}" 2>/dev/null || true
    log "Wrote AWCFG config partition payload to ${AWCFG_DEV}"
}

# ---- main ------------------------------------------------------------------

AB=0
if [ $# -eq 0 ]; then
    # Bare interactive invocation -> launch the friendly TUI installer. The
    # manager always passes --target/--list-json and skips this.
    if [ -t 0 ] && command -v dialog >/dev/null 2>&1 && [ -x /opt/airwaves/scripts/airwaves-firstrun ]; then
        exec /opt/airwaves/scripts/airwaves-firstrun --install
    fi
    fail "usage: airwaves-install [--ab] --target <disk> | --list-json | --scan-json"
fi
while [ $# -gt 0 ]; do
    case "$1" in
        --list-json) list_targets_json; exit 0 ;;
        --scan-json) scan_targets_json; exit 0 ;;
        --ab)        AB=1; shift ;;
        --target)    TARGET="${2:-}"; shift 2 ;;
        --config)    INSTALL_CONFIG="${2:-}"; shift 2 ;;
        *)           TARGET="$1"; shift ;;
    esac
done

write_status
preflight
case "${PLATFORM}" in
    uefi-x86)
        if [ "${AB}" = "1" ]; then partition_x86_ab; copy_rootfs_ab; bootloader_x86_ab
        else partition_x86; copy_rootfs; bootloader_x86; fi ;;
    uboot)
        [ "${AB}" = "1" ] && fail "A/B is not yet supported on u-boot/ARM boards (later phase); install without --ab"
        partition_uboot; copy_rootfs; bootloader_uboot ;;
    rpi)
        [ "${AB}" = "1" ] && fail "A/B is not yet supported on Raspberry Pi (later phase); install without --ab"
        partition_rpi;   copy_rootfs; bootloader_rpi ;;
    *)        fail "Unsupported platform: ${PLATFORM}" ;;
esac

# Seed the target's AWCFG config partition (applied by the target on first boot).
apply_awcfg_payload

STATE="success"
PHASE="done"
